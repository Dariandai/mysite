---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dar1an | Portfolio and others',
  description = 'UI/UX Designer \& Developer - Exploring the boundaries between design and code.'
} = Astro.props;

const navItems = [
  { id: 'home', en: 'Home', cn: '主页', url: '/#home' },
  { id: 'about', en: 'About', cn: '关于', url: '/about/' },
  { id: 'blog', en: 'Blog', cn: '博客', url: '/blog/' },
  { id: 'portfolio', en: 'Works', cn: '作品', url: '/portfolio/' },
  { id: 'share', en: 'Share', cn: '分享', url: '/share/' }
];

// 判断当前页面是否需要显示返回按钮（非首页）
const isHomePage = Astro.url.pathname === '/';
const showBackButton = !isHomePage;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css">
  <!-- GSAP for smooth scroll animations -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollToPlugin.min.js" is:inline></script>
  <style is:global>
    @import '../styles/global.css';
  </style>
  <style>
    /* Back Button Fixed Position */
    .back-button-fixed {
      position: fixed;
      top: 100px;
      left: 40px;
      z-index: 999;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      background: none;
      border: none;
      color: var(--text-muted, #888);
      cursor: pointer;
      padding: 10px;
      font-family: inherit;
      transition: all 0.3s ease;
    }

    .back-button-fixed:hover {
      color: var(--text-main, #fff);
      transform: translateX(-3px);
    }

    .back-button-fixed i {
      font-size: 1.5rem;
    }

    .back-text {
      display: flex;
      flex-direction: column;
      align-items: center;
      font-size: 0.75rem;
    }

    .back-text .cn {
      font-size: 0.65rem;
      opacity: 0.8;
    }

    /* Responsive for tablet */
    @media (max-width: 1024px) {
      .back-button-fixed {
        left: 20px;
        top: 90px;
      }
    }

    /* Tablet - show fixed back button */
    @media (min-width: 769px) {
      .back-button-nav {
        display: none !important;
      }
    }

    /* Nav left container */
    .nav-left {
      display: flex;
      align-items: center;
      gap: 15px;
    }

    /* Back button in nav */
    .back-button-nav {
      display: none;
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      padding: 5px;
      transition: color 0.3s ease;
    }

    .back-button-nav:hover {
      color: var(--text-main);
    }

    /* Mobile: show nav back button, hide fixed back button */
    @media (max-width: 768px) {
      .back-button-nav {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .back-button-fixed {
        display: none !important;
      }

      .nav-left {
        gap: 10px;
      }
    }

    /* Hide back button when mobile menu is open */
    .mobile-nav.active ~ .back-button-fixed,
    .mobile-nav-overlay.active ~ .back-button-fixed {
      display: none;
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <header id="navbar">
    <div class="nav-left">
      {showBackButton && (
        <button class="back-button-nav" onclick="goBack()" aria-label="Go back">
          <i class="ri-arrow-left-line"></i>
        </button>
      )}
      <a href="/" class="logo">
        <img src="https://img.dar1an.dpdns.org/Picgo/2025/12-02-20-24-54.png" alt="Avatar">
        <span>Dar1an</span>
      </a>
    </div>
    <nav class="nav-links">
      {navItems.map(item => {
        const isActive = item.id === 'home'
          ? Astro.url.pathname === '/'
          : Astro.url.pathname.startsWith(item.url);
        return (
        <a
          href={item.url}
          class={`nav-anchor ${isActive ? 'active' : ''}`}
          data-target={item.id}
        >
          <div class="nav-link-item">
            <span class="en">{item.en}</span>
            <span class="cn">{item.cn}</span>
          </div>
        </a>
      );})}
    </nav>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" aria-label="Menu" onclick="toggleMobileMenu()">
      <i class="ri-menu-line" id="menu-icon-open"></i>
      <i class="ri-close-line" id="menu-icon-close" style="display: none;"></i>
    </button>
  </header>

  <!-- Mobile Navigation Drawer -->
  <nav class="mobile-nav" id="mobile-nav">
    {navItems.map(item => {
      const isActive = item.id === 'home'
        ? Astro.url.pathname === '/'
        : Astro.url.pathname.startsWith(item.url);
      return (
      <a
        href={item.url}
        class={`mobile-nav-link ${isActive ? 'active' : ''}`}
        onclick="closeMobileMenu()"
      >
        <span class="en">{item.en}</span>
        <span class="cn">{item.cn}</span>
      </a>
    )})}
  </nav>
  <div class="mobile-nav-overlay" id="mobile-nav-overlay" onclick="closeMobileMenu()"></div>

  <!-- Back Button (Fixed Left Top) -->
  {showBackButton && (
    <button class="back-button-fixed" onclick="goBack()" aria-label="Go back">
      <i class="ri-arrow-left-line"></i>
      <span class="back-text">
        <span class="en">Back</span>
        <span class="cn">返回</span>
      </span>
    </button>
  )}

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <script>
    // Navbar scroll effect
    const header = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    });

    // Mobile Menu Functions
    function toggleMobileMenu() {
      const mobileNav = document.getElementById('mobile-nav');
      const overlay = document.getElementById('mobile-nav-overlay');
      const menuIconOpen = document.getElementById('menu-icon-open');
      const menuIconClose = document.getElementById('menu-icon-close');
      const body = document.body;

      if (mobileNav?.classList.contains('active')) {
        closeMobileMenu();
      } else {
        mobileNav?.classList.add('active');
        overlay?.classList.add('active');
        if (menuIconOpen) menuIconOpen.style.display = 'none';
        if (menuIconClose) menuIconClose.style.display = 'block';
        body.style.overflow = 'hidden';
      }
    }

    function closeMobileMenu() {
      const mobileNav = document.getElementById('mobile-nav');
      const overlay = document.getElementById('mobile-nav-overlay');
      const menuIconOpen = document.getElementById('menu-icon-open');
      const menuIconClose = document.getElementById('menu-icon-close');
      const body = document.body;

      mobileNav?.classList.remove('active');
      overlay?.classList.remove('active');
      if (menuIconOpen) menuIconOpen.style.display = 'block';
      if (menuIconClose) menuIconClose.style.display = 'none';
      body.style.overflow = '';
    }

    // Make mobile menu functions available globally
    (window as any).toggleMobileMenu = toggleMobileMenu;
    (window as any).closeMobileMenu = closeMobileMenu;

    // Close mobile menu on window resize (if switching to desktop)
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) {
        closeMobileMenu();
      }
    });

    // Go back function for back button
    function goBack() {
      // Check if there's a referrer from the same site
      if (document.referrer && document.referrer.includes(window.location.hostname)) {
        history.back();
      } else {
        // If no referrer, go to homepage
        window.location.href = '/';
      }
    }

    // Make goBack available globally
    (window as any).goBack = goBack;
  </script>
</body>
</html>
