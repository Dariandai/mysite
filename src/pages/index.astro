---
import BaseLayout from '../layouts/BaseLayout.astro';

const blogPosts = [
    {
        date: '2026.03.03',
        titleEn: 'Understanding the Brain',
        titleCn: '认识大脑：为什么我总是想偷懒',
        excerpt: '从脑科学角度理解拖延与焦虑，找到与自己和解的方法。',
        url: '/blog/brain-science/'
    },
    {
        date: '2026.02.24',
        titleEn: 'The Two Types of Magic',
        titleCn: '两种魔术：刘谦给罗永浩上的那堂课',
        excerpt: '听完四小时播客，重新理解魔术的价值。',
        url: '/blog/luo-yonghao-liu-qian/'
    },
    {
        date: '2025.08.11',
        titleEn: 'Running AI Locally',
        titleCn: '在本地跑AI：从折腾到真香',
        excerpt: 'WSL2 + llama.cpp/vLLM 部署踩坑记录。',
        url: '/blog/local-ai/'
    }
];

const works = [
    {
        titleEn: 'File Tools ',
        titleCn: '本地文件智能检索与问答系统',
        image: 'https://img.dar1an.dpdns.org/Picgo/2026/03-09-02-46-33.png',
        url: '/portfolio/project-alpha/'
    },
    {
        titleEn: 'System UI',
        titleCn: '后台数据可视化界面',
        image: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2670&auto=format&fit=crop',
        url: '/portfolio/'
    }
];

const tools = [
    { name: 'Figma', desc: '最强大的界面协作设计工具。', icon: 'ri-pencil-ruler-2-fill' },
    { name: 'GitHub', desc: '全球最大的开源代码托管平台。', icon: 'ri-github-fill' },
    { name: 'Dribbble', desc: '寻找顶级设计师的灵感社区。', icon: 'ri-dribbble-line' },
    { name: 'Vercel', desc: '极速的前端部署与托管平台。', icon: 'ri-cloud-windy-fill' }
];

const skills = [
    { category: 'Development', icon: 'ri-code-box-line', items: ['Python / PyTorch / Flask', 'FastAPI / RESTful API', 'HTML / CSS / JavaScript', 'Java'] },
    { category: 'Testing', icon: 'ri-bug-line', items: ['Selenium / Pytest / Requests', 'JMeter Performance Testing', 'Postman API Testing', 'Test Case Design / CI'] },
    { category: 'Tools & DB', icon: 'ri-database-2-line', items: ['MySQL / MongoDB', 'Git / Docker / Linux', 'JIRA / 禅道', 'Swagger / Node.js'] }
];
---

<BaseLayout>
    <!-- 1. 主页 (Home) -->
    <section id="home">
        <div class="hero-text">
            <div class="hero-label">
                <span class="en">WORK IN PROGRESS &amp; DEVELOPER</span>
            </div>
            <h1 class="en">Hello,<br>I'm Darian<span class="hero-cn-inline">·代宇</span></h1>
            <div class="text-group" style="margin-top: 20px;">
                <p class="en" style="color: var(--text-muted); font-size: 1rem; line-height: 1.7; max-width: 420px;">Finding my way and digging deep into how things work. Training for the long game.</p>
                <p class="cn" style="margin-top: 6px;">探索技术之径，穷理事物之微，修身砺志赴远。</p>
            </div>

            <a href="/portfolio/" class="btn-connect">
                <span class="en">Check Portfolio</span>
                <span class="cn">查看作品</span>
            </a>
        </div>

        <div class="hero-img">
            <img src="https://img.dar1an.dpdns.org/Picgo/2025/12-02-20-24-54.png" alt="Personal Photo">
        </div>
    </section>

    <!-- 2. 关于 (About) -->
    <section id="about">
        <h2 class="section-title">
            <span class="sub">Skills & Tools / 技能与工具</span>
            <div class="text-group">
                <a href="/about/" class="section-link">
                    <span class="en">What I Do</span>
                    <span class="cn" style="font-size: 1.2rem;">我的技能栈</span>
                </a>
            </div>
        </h2>
        <div class="skills-grid">
            {skills.map(skill => (
                <div class="card">
                    <div class="card-header">
                        <i class={skill.icon}></i>
                        <span>{skill.category}</span>
                    </div>
                    <ul class="card-list">
                        {skill.items.map(item => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
        <div class="skills-cta">
            <a href="/about/" class="btn-connect">
                <span class="en">Learn More About Me</span>
                <span class="cn">了解更多关于我</span>
            </a>
        </div>
    </section>

    <!-- 3. 博客 (Blog) -->
    <section id="blog">
        <h2 class="section-title">
            <span class="sub">Thinking / 思考</span>
            <div class="text-group">
                <a href="/blog/" class="section-link">
                    <span class="en">Latest Articles</span>
                    <span class="cn" style="font-size: 1.2rem;">最新博客文章</span>
                </a>
            </div>
        </h2>
        <div class="skills-grid">
            {blogPosts.map(post => (
                <a href={post.url} class="card blog-card">
                    <div class="card-header">
                        <i class="ri-article-line"></i>
                        <span>{post.date}</span>
                    </div>
                    <div class="text-group">
                        <span class="en" style="font-weight: 500; font-size: 1.1rem;">{post.titleEn}</span>
                        <span class="cn" style="margin-top: 6px;">{post.titleCn}</span>
                    </div>
                    <p class="cn" style="margin-top: 12px; font-size: 0.9rem;">{post.excerpt}</p>
                </a>
            ))}
        </div>
    </section>

    <!-- 3. 作品 (Works) -->
    <section id="portfolio">
        <h2 class="section-title">
            <span class="sub">Selected Works / 作品集</span>
            <div class="text-group">
                <a href="/portfolio/" class="section-link">
                    <span class="en">Portfolio Showcase</span>
                    <span class="cn" style="font-size: 1.2rem;">精选项目展示</span>
                </a>
            </div>
        </h2>
        <div class="works-gallery">
            {works.map(work => (
                <a href={work.url} class="work-item">
                    <img src={work.image} alt={work.titleEn}>
                    <div class="work-info text-group">
                        <h4 class="en">{work.titleEn}</h4>
                        <p class="cn">{work.titleCn}</p>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <!-- 4. 分享 (Share) -->
    <section id="share">
        <h2 class="section-title">
            <span class="sub">Tools & Resources / 工具资源</span>
            <div class="text-group">
                <a href="/share/" class="section-link">
                    <span class="en">Worth Sharing</span>
                    <span class="cn" style="font-size: 1.2rem;">好用的工具与网站推荐</span>
                </a>
            </div>
        </h2>

        <div class="skills-grid">
            {tools.map(tool => (
                <a href="/share/" class="card tool-card">
                    <div class="card-header">
                        <i class={tool.icon}></i>
                        <span>{tool.name}</span>
                    </div>
                    <ul class="card-list">
                        <li>{tool.desc}</li>
                    </ul>
                </a>
            ))}
        </div>

        <footer>
            <div class="text-group">
                <span class="en">&copy; 2026 Dar1an. All Rights Reserved.</span>
                <span class="cn">保留所有权利。</span>
            </div>
        </footer>
    </section>
</BaseLayout>

<script>
    // 使用统一的堆叠卡片模块
    import { initStackingCards } from '/src/scripts/stacking-cards.js';

    const sectionOrder = ['home', 'about', 'blog', 'portfolio', 'share'];

    initStackingCards({
        sections: 'section',
        sectionOrder: sectionOrder,
        onSectionChange: (index) => {
            updateNavHighlight(sectionOrder[index]);
        }
    });

    // 导航高亮更新
    function updateNavHighlight(activeId) {
        document.querySelectorAll('.nav-anchor').forEach(anchor => {
            if (anchor.getAttribute('data-target') === activeId) {
                anchor.classList.add('active');
            } else {
                anchor.classList.remove('active');
            }
        });
    }

    // 导航点击事件
    document.querySelectorAll('.nav-anchor').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href && href.startsWith('#')) {
                e.preventDefault();
                const targetId = this.getAttribute('data-target');
                const targetIndex = sectionOrder.indexOf(targetId || '');
                // 获取实例并滚动到指定section
                const instance = window.stackingCardsInstance;
                if (instance && targetIndex >= 0) {
                    instance.scrollToSection(targetIndex);
                }
            }
        });
    });
</script>
