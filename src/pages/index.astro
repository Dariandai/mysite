---
import BaseLayout from '../layouts/BaseLayout.astro';

const blogPosts = [
    {
        date: '2026.03.03',
        titleEn: 'Understanding the Brain',
        titleCn: '认识大脑：为什么我总是想偷懒',
        excerpt: '从脑科学角度理解拖延与焦虑，找到与自己和解的方法。',
        url: '/blog/brain-science/'
    },
    {
        date: '2026.02.24',
        titleEn: 'The Two Types of Magic',
        titleCn: '两种魔术：刘谦给罗永浩上的那堂课',
        excerpt: '听完四小时播客，重新理解魔术的价值。',
        url: '/blog/luo-yonghao-liu-qian/'
    },
    {
        date: '2025.08.11',
        titleEn: 'Running AI Locally',
        titleCn: '在本地跑AI：从折腾到真香',
        excerpt: 'WSL2 + llama.cpp/vLLM 部署踩坑记录。',
        url: '/blog/local-ai/'
    }
];

const works = [
    {
        titleEn: 'File Tools ',
        titleCn: '本地文件智能检索与问答系统',
        image: 'https://img.dar1an.dpdns.org/Picgo/2026/03-09-02-46-33.png',
        url: '/portfolio/project-alpha/'
    },
    {
        titleEn: 'System UI',
        titleCn: '后台数据可视化界面',
        image: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2670&auto=format&fit=crop',
        url: '/portfolio/'
    }
];

const tools = [
    { name: 'Figma', desc: '最强大的界面协作设计工具。', icon: 'ri-pencil-ruler-2-fill' },
    { name: 'GitHub', desc: '全球最大的开源代码托管平台。', icon: 'ri-github-fill' },
    { name: 'Dribbble', desc: '寻找顶级设计师的灵感社区。', icon: 'ri-dribbble-line' },
    { name: 'Vercel', desc: '极速的前端部署与托管平台。', icon: 'ri-cloud-windy-fill' }
];

const skills = [
    { category: 'Development', icon: 'ri-code-box-line', items: ['Python / PyTorch / Flask', 'FastAPI / RESTful API', 'HTML / CSS / JavaScript', 'Java'] },
    { category: 'Testing', icon: 'ri-bug-line', items: ['Selenium / Pytest / Requests', 'JMeter Performance Testing', 'Postman API Testing', 'Test Case Design / CI'] },
    { category: 'Tools & DB', icon: 'ri-database-2-line', items: ['MySQL / MongoDB', 'Git / Docker / Linux', 'JIRA / 禅道', 'Swagger / Node.js'] }
];
---

<BaseLayout>
    <!-- 1. 主页 (Home) -->
    <section id="home">
        <div class="hero-text">
            <div class="text-group">
                <p class="en" style="color: var(--text-muted);">WORK IN PROGRESS & DEVELOPER</p>
                <p class="cn">探索 / 开发</p>
            </div>
            <br>
            <div class="text-group">
                <h1 class="en">Hello,<br>It's Darian.</h1><h2>代宇</h2>
            </div>
            <br>
            <div class="text-group">
                <p class="en" style="color: var(--text-muted);">Finding my way and digging deep into how things work.Training for the long game.</p>
                <p class="cn">探索技术之径，穷理事物之微，修身砺志赴远。</p>
            </div>

            <a href="/portfolio/" class="btn-connect">
                <span class="en">Check Portfolio</span>
                <span class="cn">查看个人作品</span>
            </a>
        </div>

        <div class="hero-img">
            <img src="https://img.dar1an.dpdns.org/Picgo/2025/12-02-20-24-54.png" alt="Personal Photo">
        </div>
    </section>

    <!-- 2. 关于 (About) -->
    <section id="about">
        <h2 class="section-title">
            <span class="sub">Skills & Tools / 技能与工具</span>
            <div class="text-group">
                <a href="/about/" class="section-link">
                    <span class="en">What I Do</span>
                    <span class="cn" style="font-size: 1.2rem;">我的技能栈</span>
                </a>
            </div>
        </h2>
        <div class="skills-showcase">
            {skills.map(skill => (
                <div class="skill-block">
                    <div class="skill-header">
                        <i class={skill.icon}></i>
                        <h3 class="skill-cat">{skill.category}</h3>
                    </div>
                    <ul class="skill-items">
                        {skill.items.map(item => (
                            <li>{item}</li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
        <div class="skills-cta">
            <a href="/about/" class="btn-connect">
                <span class="en">Learn More About Me</span>
                <span class="cn">了解更多关于我</span>
            </a>
        </div>
    </section>

    <!-- 3. 博客 (Blog) -->
    <section id="blog">
        <h2 class="section-title">
            <span class="sub">Thinking / 思考</span>
            <div class="text-group">
                <a href="/blog/" class="section-link">
                    <span class="en">Latest Articles</span>
                    <span class="cn" style="font-size: 1.2rem;">最新博客文章</span>
                </a>
            </div>
        </h2>
        <div class="blog-grid">
            {blogPosts.map(post => (
                <a href={post.url} class="blog-card">
                    <div class="blog-date">{post.date}</div>
                    <div class="text-group">
                        <h3 class="en">{post.titleEn}</h3>
                        <h3 class="cn">{post.titleCn}</h3>
                        <p class="cn" style="margin-top:10px;">{post.excerpt}</p>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <!-- 3. 作品 (Works) -->
    <section id="portfolio">
        <h2 class="section-title">
            <span class="sub">Selected Works / 作品集</span>
            <div class="text-group">
                <a href="/portfolio/" class="section-link">
                    <span class="en">Portfolio Showcase</span>
                    <span class="cn" style="font-size: 1.2rem;">精选项目展示</span>
                </a>
            </div>
        </h2>
        <div class="works-gallery">
            {works.map(work => (
                <a href={work.url} class="work-item">
                    <img src={work.image} alt={work.titleEn}>
                    <div class="work-info text-group">
                        <h4 class="en">{work.titleEn}</h4>
                        <p class="cn">{work.titleCn}</p>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <!-- 4. 分享 (Share) -->
    <section id="share">
        <h2 class="section-title">
            <span class="sub">Tools & Resources / 工具资源</span>
            <div class="text-group">
                <a href="/share/" class="section-link">
                    <span class="en">Worth Sharing</span>
                    <span class="cn" style="font-size: 1.2rem;">好用的工具与网站推荐</span>
                </a>
            </div>
        </h2>

        <div class="share-grid">
            {tools.map(tool => (
                <a href="/share/" class="tool-card">
                    <div class="tool-icon"><i class={tool.icon}></i></div>
                    <div class="text-group">
                        <span class="en" style="font-weight:bold;">{tool.name}</span>
                        <span class="cn">{tool.desc}</span>
                    </div>
                </a>
            ))}
        </div>

        <footer>
            <div class="text-group">
                <span class="en">&copy; 2026 Dar1an. All Rights Reserved.</span>
                <span class="cn">保留所有权利。</span>
            </div>
        </footer>
    </section>
</BaseLayout>

<script>
    // GSAP Stacking Cards - 采用 GSAP 社区最佳实践: Pinned Section + 内部滚动监听 + 吸附阻尼
    function initGSAPAnimations() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
            setTimeout(initGSAPAnimations, 100);
            return;
        }

        gsap.registerPlugin(ScrollTrigger);

        const sections = document.querySelectorAll('section');
        const sectionOrder = ['home', 'about', 'blog', 'portfolio', 'share'];

        // 状态管理
        const SectionPhase = {
            HIDDEN: 'hidden',
            ENTERING: 'entering',
            ACTIVE: 'active',
            EXITING: 'exiting'
        };

        const sectionStates = Array.from(sections).map(() => ({
            phase: SectionPhase.HIDDEN,
            isAtTop: true,
            isAtBottom: false,
            wrapper: null
        }));

        // 初始化第一个section为活跃状态
        sectionStates[0].phase = SectionPhase.ACTIVE;
        sectionStates[0].isAtTop = true;

        let currentSectionIndex = 0;
        let isTransitioning = false;
        let accumulatedDelta = 0; // 用于阻尼效果
        const DAMPING_THRESHOLD = 400; // 增加阻尼阈值，让滑动过程更明显，能看到模糊渐变

        // 检测设备类型 - 包含横屏检测
        const isMobile = () => window.innerWidth <= 768;
        const isLandscape = () => window.innerHeight <= 500 && window.innerWidth > window.innerHeight;
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // 清理已存在的wrapper避免重复
        function cleanup() {
            sections.forEach(section => {
                const existingWrapper = section.querySelector('.section-scroll-wrapper');
                if (existingWrapper) {
                    const content = existingWrapper.querySelector('.section-scroll-content');
                    if (content) {
                        const children = Array.from(content.children);
                        children.forEach(child => section.appendChild(child));
                    }
                    existingWrapper.remove();
                }
                const existingOverlay = section.querySelector('.blur-overlay');
                if (existingOverlay) existingOverlay.remove();
            });
            ScrollTrigger.getAll().forEach(st => st.kill());
        }

        cleanup();

        // 设置初始样式
        sections.forEach((section, index) => {
            const zIndex = (index + 1) * 10;
            section.setAttribute('data-gsap', 'true');
            section.style.zIndex = String(zIndex);
            section.style.position = 'sticky';
            section.style.top = '0';
            section.style.left = '0';
            section.style.width = '100%';
            section.style.height = '100vh';
            section.style.opacity = '1';
            section.style.overflow = 'hidden';
            section.style.backgroundColor = 'var(--bg-color, #050505)';
        });

        // 创建内容包装器
        const wrappers = [];
        sections.forEach((section, index) => {
            const children = Array.from(section.children);
            const wrapper = document.createElement('div');
            wrapper.className = 'section-scroll-wrapper';
            wrapper.style.cssText = `
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                overflow-y: ${index === 0 ? 'auto' : 'hidden'};
                overflow-x: hidden;
                -webkit-overflow-scrolling: touch;
                z-index: 1;
            `;

            const content = document.createElement('div');
            content.className = 'section-scroll-content';
            const homeFlag = section.id === 'home';
            const mobileFlag = isMobile();
            const landscapeFlag = isLandscape();
            content.style.cssText = `
                min-height: 100vh;
                padding: ${landscapeFlag ? '60px 5% 20px' : '100px 10% 50px'};
                box-sizing: border-box;
                display: flex;
                flex-direction: ${homeFlag && !mobileFlag ? 'row' : 'column'};
                ${homeFlag && !mobileFlag ? 'align-items: center; justify-content: space-between;' : ''}
            `;

            children.forEach(child => content.appendChild(child));
            wrapper.appendChild(content);
            section.appendChild(wrapper);
            wrappers.push(wrapper);
            sectionStates[index].wrapper = wrapper;

            // 为每个section（除了最后一个）添加模糊遮罩层
            if (index === sections.length - 1) return;

            const blurOverlay = document.createElement('div');
            blurOverlay.className = 'blur-overlay';
            blurOverlay.style.cssText = `
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                backdrop-filter: blur(0px);
                background: rgba(5, 5, 5, 0);
                pointer-events: none;
                z-index: 9999;
                transition: backdrop-filter 0.3s ease, background 0.3s ease;
            `;
            section.appendChild(blurOverlay);
        });

        // 更新所有section的模糊状态 - 使用GSAP动画让渐变过程更明显
        function updateBlurStates() {
            sections.forEach((section, index) => {
                const blurOverlay = section.querySelector('.blur-overlay');
                if (!blurOverlay) return;

                if (index < currentSectionIndex) {
                    // 当前section之前的所有section都应该有模糊
                    gsap.to(blurOverlay, {
                        backdropFilter: 'blur(15px)',
                        background: 'rgba(5, 5, 5, 0.6)',
                        duration: 1.0, // 增加动画持续时间
                        ease: 'power2.inOut'
                    });
                } else {
                    // 当前及之后的section没有模糊
                    gsap.to(blurOverlay, {
                        backdropFilter: 'blur(0px)',
                        background: 'rgba(5, 5, 5, 0)',
                        duration: 1.0, // 增加动画持续时间
                        ease: 'power2.inOut'
                    });
                }
            });
        }

        // 监听内部滚动位置
        wrappers.forEach((wrapper, index) => {
            wrapper.addEventListener('scroll', () => {
                if (sectionStates[index].phase !== SectionPhase.ACTIVE) return;

                const { scrollTop, scrollHeight, clientHeight } = wrapper;
                sectionStates[index].isAtTop = scrollTop <= 5;
                sectionStates[index].isAtBottom = scrollTop + clientHeight >= scrollHeight - 5;
            }, { passive: true });
        });

        // 滚动到指定section - 带吸附阻尼效果
        function goToSection(targetIndex) {
            if (isTransitioning || targetIndex < 0 || targetIndex >= sections.length) return;
            if (targetIndex === currentSectionIndex) return;

            // 限制最后一个section的滚动 - share 之后不能再滚
            if (targetIndex > sections.length - 1) return;

            const direction = targetIndex > currentSectionIndex ? 'next' : 'prev';
            isTransitioning = true;
            accumulatedDelta = 0; // 重置累积滚动量

            const prevIndex = currentSectionIndex;
            currentSectionIndex = targetIndex;

            // 更新状态
            sectionStates[prevIndex].phase = direction === 'next' ? SectionPhase.HIDDEN : SectionPhase.ACTIVE;
            sectionStates[targetIndex].phase = SectionPhase.ACTIVE;

            // 禁用所有wrapper滚动，启用当前wrapper
            wrappers.forEach((w, i) => {
                w.style.overflowY = i === targetIndex ? 'auto' : 'hidden';
                if (i === targetIndex) {
                    // 重置scroll位置用于新section
                    if (direction === 'next') {
                        w.scrollTop = 0;
                        sectionStates[i].isAtTop = true;
                        sectionStates[i].isAtBottom = false;
                    }
                }
            });

            // 更新模糊状态
            updateBlurStates();

            // 滚动到目标位置 - 使用更慢的动画让模糊渐变过程可见
            const targetScroll = targetIndex * window.innerHeight;

            gsap.to(window, {
                duration: 1.2, // 增加动画持续时间，让滑动过程更明显
                scrollTo: { y: targetScroll, autoKill: false },
                ease: 'power2.inOut', // 使用更平滑的缓动
                onComplete: () => {
                    isTransitioning = false;
                    updateNavHighlight(sectionOrder[targetIndex]);
                }
            });
        }

        // Wheel 事件处理 - 带吸附阻尼效果
        function handleWheel(e) {
            // 如果在最后一个section且已经到底，阻止继续向下滚动
            if (currentSectionIndex === sections.length - 1) {
                const currentState = sectionStates[currentSectionIndex];
                if (currentState.isAtBottom && e.deltaY > 0) {
                    e.preventDefault();
                    return;
                }
            }

            if (isTransitioning) {
                e.preventDefault();
                return;
            }

            const currentState = sectionStates[currentSectionIndex];
            const deltaY = e.deltaY;

            // 阻尼逻辑：在边界附近增加阻力
            const isAtBoundary = currentState.isAtTop || currentState.isAtBottom;
            const isScrollingOutward = (deltaY > 0 && currentState.isAtBottom) ||
                                        (deltaY < 0 && currentState.isAtTop);

            if (isAtBoundary && isScrollingOutward) {
                // 累积滚动量
                accumulatedDelta += Math.abs(deltaY);

                // 未达到阈值时阻止默认行为并累积
                if (accumulatedDelta < DAMPING_THRESHOLD) {
                    e.preventDefault();

                    // 应用阻尼效果 - 视觉反馈
                    const currentWrapper = wrappers[currentSectionIndex];
                    if (currentWrapper) {
                        const resistance = 1 - (accumulatedDelta / DAMPING_THRESHOLD) * 0.3;
                        // 轻微的视觉反馈
                        currentWrapper.style.transform = `translateY(${deltaY > 0 ? -5 : 5} * ${1 - resistance}px)`;
                        setTimeout(() => {
                            currentWrapper.style.transform = '';
                        }, 50);
                    }
                    return;
                }

                // 达到阈值，执行切换
                accumulatedDelta = 0;

                // 向下滚动
                if (deltaY > 0 && currentSectionIndex < sections.length - 1) {
                    e.preventDefault();
                    goToSection(currentSectionIndex + 1);
                    return;
                }

                // 向上滚动
                if (deltaY < 0 && currentSectionIndex > 0) {
                    e.preventDefault();
                    goToSection(currentSectionIndex - 1);
                    return;
                }
            } else {
                // 不在边界或不是向外滚动，重置累积
                accumulatedDelta = 0;

                // 如果在内部滚动区域，允许默认行为
                if (!currentState.isAtTop && deltaY < 0) return;
                if (!currentState.isAtBottom && deltaY > 0) return;
            }
        }

        // 触摸设备支持 - 同样带阻尼效果
        let touchStartY = 0;
        let touchAccumulatedDelta = 0;

        function handleTouchStart(e) {
            touchStartY = e.touches[0].clientY;
            touchAccumulatedDelta = 0;
        }

        function handleTouchMove(e) {
            // 如果在最后一个section且已经到底，阻止继续向下滚动
            if (currentSectionIndex === sections.length - 1) {
                const currentState = sectionStates[currentSectionIndex];
                const touchY = e.touches[0].clientY;
                const deltaY = touchStartY - touchY;
                if (currentState.isAtBottom && deltaY > 0) {
                    e.preventDefault();
                    return;
                }
            }

            if (isTransitioning) {
                e.preventDefault();
                return;
            }

            const touchY = e.touches[0].clientY;
            const deltaY = touchStartY - touchY;
            const currentState = sectionStates[currentSectionIndex];
            const currentWrapper = wrappers[currentSectionIndex];

            // 灵敏度阈值
            const threshold = 30;

            // 在边界时累积
            const isAtBoundary = currentState.isAtTop || currentState.isAtBottom;
            const isScrollingOutward = (deltaY > threshold && currentState.isAtBottom) ||
                                        (deltaY < -threshold && currentState.isAtTop);

            if (isAtBoundary && Math.abs(deltaY) > threshold) {
                touchAccumulatedDelta += Math.abs(deltaY);

                if (touchAccumulatedDelta < DAMPING_THRESHOLD) {
                    e.preventDefault();
                    return;
                }

                touchAccumulatedDelta = 0;

                // 向下滚动（手指向上滑）
                if (deltaY > threshold && currentSectionIndex < sections.length - 1) {
                    e.preventDefault();
                    goToSection(currentSectionIndex + 1);
                    touchStartY = touchY;
                    return;
                }

                // 向上滚动（手指向下滑）
                if (deltaY < -threshold && currentSectionIndex > 0) {
                    e.preventDefault();
                    goToSection(currentSectionIndex - 1);
                    touchStartY = touchY;
                    return;
                }
            }

            // 检查是否可以内部滚动
            if (deltaY > 0 && !currentState.isAtBottom) return; // 向下但未到顶
            if (deltaY < 0 && !currentState.isAtTop) return; // 向上但未到顶
        }

        // 绑定事件
        window.addEventListener('wheel', handleWheel, { passive: false });
        window.addEventListener('touchstart', handleTouchStart, { passive: true });
        window.addEventListener('touchmove', handleTouchMove, { passive: false });

        // 导航点击
        document.querySelectorAll('.nav-anchor').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href && href.startsWith('#')) {
                    e.preventDefault();
                    const targetId = this.getAttribute('data-target');
                    const targetIndex = sectionOrder.indexOf(targetId || '');
                    if (targetIndex >= 0) {
                        goToSection(targetIndex);
                    }
                }
            });
        });

        // 键盘导航
        window.addEventListener('keydown', (e) => {
            if (isTransitioning) return;

            const currentState = sectionStates[currentSectionIndex];

            if (e.key === 'ArrowDown' || e.key === 'PageDown') {
                e.preventDefault();
                if (currentState.isAtBottom && currentSectionIndex < sections.length - 1) {
                    accumulatedDelta = DAMPING_THRESHOLD; // 跳过阻尼
                    goToSection(currentSectionIndex + 1);
                }
            }
            if (e.key === 'ArrowUp' || e.key === 'PageUp') {
                e.preventDefault();
                if (currentState.isAtTop && currentSectionIndex > 0) {
                    accumulatedDelta = DAMPING_THRESHOLD; // 跳过阻尼
                    goToSection(currentSectionIndex - 1);
                }
            }
        });

        function updateNavHighlight(activeId) {
            document.querySelectorAll('.nav-anchor').forEach(anchor => {
                if (anchor.getAttribute('data-target') === activeId) {
                    anchor.classList.add('active');
                } else {
                    anchor.classList.remove('active');
                }
            });
        }

        // 设置 body 高度 - 最后一个section只给1vh的滚动空间
        const totalHeight = sections.length * window.innerHeight;
        document.body.style.height = `${totalHeight}px`;

        // 窗口大小改变时重新初始化
        let resizeTimeout;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                cleanup();
                initGSAPAnimations();
            }, 300);
        });

        // 初始化模糊状态
        updateBlurStates();
    }

    // 检查是否支持减少动画偏好
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
        initSimpleNavigation();
    } else {
        initGSAPAnimations();
    }

    // 简单的导航功能（减少动画模式时使用）
    function initSimpleNavigation() {
        const sectionOrder = ['home', 'about', 'blog', 'portfolio', 'share'];

        // 恢复默认样式
        const sections = document.querySelectorAll('section');
        sections.forEach((section) => {
            section.style.position = 'relative';
            section.style.opacity = '1';
            section.style.visibility = 'visible';
            section.style.transform = 'none';
            section.style.height = 'auto';
            section.style.minHeight = '100vh';
        });
        document.body.style.height = 'auto';

        document.querySelectorAll('.nav-anchor').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                if (href && href.startsWith('#')) {
                    e.preventDefault();
                    const targetId = this.getAttribute('data-target');
                    if (targetId) {
                        const element = document.getElementById(targetId);
                        if (element) {
                            element.scrollIntoView({ behavior: 'smooth' });
                        }
                    }
                }
            });
        });

        const navAnchors = document.querySelectorAll('.nav-anchor');

        function updateActiveNav() {
            const vh = window.innerHeight;
            let currentSection = 'home';

            for (const id of sectionOrder) {
                const element = document.getElementById(id);
                if (element) {
                    const rect = element.getBoundingClientRect();
                    if (rect.top <= vh / 2 && rect.bottom >= vh / 2) {
                        currentSection = id;
                        break;
                    }
                }
            }

            navAnchors.forEach(anchor => {
                if (anchor.getAttribute('data-target') === currentSection) {
                    anchor.classList.add('active');
                } else {
                    anchor.classList.remove('active');
                }
            });
        }

        window.addEventListener('scroll', updateActiveNav);
        updateActiveNav();
    }
</script>
