---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="System UI | Dar1an" description="后台数据可视化界面">
  <div class="page-content project-page" data-stacking-cards>
    <!-- 项目概览 -->
    <section class="project-section" id="overview">
      <header class="project-header">
        <span class="project-category">Dashboard / Data Viz</span>
        <h1 class="project-title">
          <span class="en">System UI</span>
          <span class="cn">后台数据可视化界面</span>
        </h1>
      </header>
      <div class="project-image-full">
        <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2670&auto=format&fit=crop" alt="System UI Dashboard" />
      </div>
      <div class="project-intro">
        <p>一个现代化的后台数据可视化仪表盘系统，专注于简洁直观的用户体验设计。通过清晰的视觉层次和流畅的交互动画，帮助用户快速理解复杂数据，做出明智决策。</p>
        <div class="tech-tags">
          <span>Figma</span>
          <span>React</span>
          <span>Tailwind CSS</span>
          <span>Recharts</span>
          <span>Framer Motion</span>
        </div>
      </div>
    </section>

    <!-- 核心功能 -->
    <section class="project-section" id="features">
      <h2 class="section-title">核心功能</h2>
      <div class="features-grid">
        <div class="feature-card">
          <h3>实时数据监控</h3>
          <p>动态更新的图表和指标卡片，支持实时数据流展示，关键指标一目了然</p>
        </div>
        <div class="feature-card">
          <h3>响应式布局</h3>
          <p>自适应各种屏幕尺寸，从大屏展示到移动端查看都能完美呈现</p>
        </div>
        <div class="feature-card">
          <h3>暗黑模式</h3>
          <p>精心调校的深色主题，降低长时间查看的视觉疲劳，提升数据可读性</p>
        </div>
        <div class="feature-card">
          <h3>交互式图表</h3>
          <p>支持缩放、筛选、下钻等交互操作，深入探索数据细节</p>
        </div>
      </div>
    </section>

    <!-- 设计系统 -->
    <section class="project-section" id="design-system">
      <h2 class="section-title">设计系统</h2>
      <div class="arch-content">
        <div class="arch-item">
          <h3>色彩体系</h3>
          <p>以深色为基底，使用高对比度的数据色区分不同维度的信息，确保数据可视化清晰易读</p>
        </div>
        <div class="arch-item">
          <h3>字体规范</h3>
          <p>Inter 字体家族为主，数字使用等宽字体，保证数据对齐和可读性</p>
        </div>
        <div class="arch-item">
          <h3>组件库</h3>
          <p>统一的卡片、按钮、表单、表格组件，保持界面一致性，提升开发效率</p>
        </div>
        <div class="arch-item">
          <h3>间距系统</h3>
          <p>8px 为基础的间距网格，确保视觉节奏感和布局整洁</p>
        </div>
      </div>

      <div class="rag-section">
        <h3>设计原则</h3>
        <ol class="rag-steps">
          <li><strong>清晰优先：</strong>数据可视化以清晰传达信息为首要目标，避免过度装饰干扰数据本身</li>
          <li><strong>层次分明：</strong>通过颜色、大小、间距建立清晰的视觉层级，引导用户关注重点</li>
          <li><strong>即时反馈：</strong>所有交互操作都有即时的视觉反馈，让用户感知系统状态</li>
        </ol>
      </div>
    </section>

    <!-- 技术实现 -->
    <section class="project-section" id="tech">
      <div class="perf-challenges">
        <div class="perf-col">
          <h2 class="section-title">技术栈</h2>
          <ul class="perf-list">
            <li>React 18 + TypeScript 类型安全</li>
            <li>Tailwind CSS 原子化样式</li>
            <li>Recharts 数据可视化图表库</li>
            <li>Framer Motion 流畅动画</li>
            <li>Vite 快速构建工具</li>
          </ul>
        </div>
        <div class="challenges-col">
          <h2 class="section-title">技术亮点</h2>
          <div class="challenge-item">
            <h4>性能优化</h4>
            <p>使用 React.memo 和 useMemo 优化大数据量渲染，图表虚拟滚动处理万级数据点</p>
          </div>
          <div class="challenge-item">
            <h4>主题切换</h4>
            <p>CSS 变量实现无缝暗黑/亮色模式切换，支持系统主题自动适配</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 后续计划 -->
    <section class="project-section" id="future">
      <div class="future-section">
        <div class="future-plans">
          <h2 class="section-title">后续计划</h2>
          <ul>
            <li>数据导出：支持 PDF、Excel、PNG 等多种格式导出</li>
            <li>自定义仪表盘：用户可拖拽配置个性化视图</li>
            <li>多数据源：接入更多类型的数据库和 API</li>
            <li>移动端 App：基于 React Native 的移动端版本</li>
          </ul>
        </div>
        <div class="github-link">
          <a href="https://github.com/Dry-U" target="_blank" class="btn-primary">
            <i class="ri-github-fill"></i>
            <span>View on GitHub</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Unified Stacking Cards Logic (matching project-alpha)
  function initProjectStacking() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
      setTimeout(initProjectStacking, 100);
      return;
    }

    gsap.registerPlugin(ScrollTrigger);

    const sections = document.querySelectorAll('.project-page section');
    if (sections.length <= 1) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      sections.forEach(section => {
        section.style.position = 'relative';
        section.style.height = 'auto';
        section.style.minHeight = '100vh';
      });
      return;
    }

    const SectionPhase = {
      HIDDEN: 'hidden',
      ENTERING: 'entering',
      ACTIVE: 'active',
      EXITING: 'exiting'
    };

    const sectionStates = Array.from(sections).map((_, index) => ({
      phase: index === 0 ? SectionPhase.ACTIVE : SectionPhase.HIDDEN,
      isAtTop: true,
      isAtBottom: false,
      wrapper: null
    }));

    let currentSectionIndex = 0;
    let accumulatedDelta = 0;
    const DAMPING_THRESHOLD = 400;
    let isHandlingScroll = false;

    sections.forEach(section => {
      const existingWrapper = section.querySelector('.section-scroll-wrapper');
      if (existingWrapper) {
        const content = existingWrapper.querySelector('.section-scroll-content');
        if (content) {
          Array.from(content.children).forEach(child => section.appendChild(child));
        }
        existingWrapper.remove();
      }
      const existingBlur = section.querySelector('.blur-overlay');
      if (existingBlur) existingBlur.remove();
    });

    sections.forEach((section, index) => {
      section.style.cssText = `
        position: sticky;
        top: 0;
        height: 100vh;
        width: 100%;
        z-index: ${(index + 1) * 10};
        background: var(--bg-color, #050505);
        overflow: hidden;
        transform: ${index === 0 ? 'translateY(0)' : 'translateY(100%)'};
        visibility: ${index === 0 ? 'visible' : 'hidden'};
      `;
    });

    const wrappers = [];
    sections.forEach((section, index) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'section-scroll-wrapper';
      wrapper.style.cssText = `
        height: 100vh;
        width: 100%;
        overflow-y: ${index === 0 ? 'auto' : 'hidden'};
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        -ms-overflow-style: none;
      `;

      const content = document.createElement('div');
      content.className = 'section-scroll-content';
      const isMobile = window.innerWidth <= 768;
      content.style.cssText = `
        min-height: 100vh;
        padding: ${isMobile ? '80px 5% 60px' : '100px 10% 50px 140px'};
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        justify-content: center;
      `;

      Array.from(section.children).forEach(child => {
        if (!child.classList?.contains('blur-overlay')) {
          content.appendChild(child);
        }
      });

      wrapper.appendChild(content);
      section.appendChild(wrapper);
      wrappers.push(wrapper);
      sectionStates[index].wrapper = wrapper;

      if (index < sections.length - 1) {
        const blurOverlay = document.createElement('div');
        blurOverlay.className = 'blur-overlay';
        blurOverlay.style.cssText = `
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          backdrop-filter: blur(0px);
          background: rgba(5, 5, 5, 0);
          pointer-events: none;
          z-index: 9999;
        `;
        section.appendChild(blurOverlay);
      }
    });

    wrappers.forEach((wrapper, index) => {
      wrapper.addEventListener('scroll', () => {
        if (sectionStates[index].phase !== SectionPhase.ACTIVE) return;
        const { scrollTop, scrollHeight, clientHeight } = wrapper;
        sectionStates[index].isAtTop = scrollTop <= 5;
        sectionStates[index].isAtBottom = scrollTop + clientHeight >= scrollHeight - 5;
      }, { passive: true });
    });

    function updateBlurStates() {
      sections.forEach((section, index) => {
        const blurOverlay = section.querySelector('.blur-overlay');
        if (!blurOverlay) return;

        if (index < currentSectionIndex - 1) {
          gsap.to(blurOverlay, {
            backdropFilter: 'blur(20px)',
            background: 'rgba(5, 5, 5, 0.7)',
            duration: 0.3
          });
        } else if (index === currentSectionIndex - 1) {
          gsap.to(blurOverlay, {
            backdropFilter: 'blur(20px)',
            background: 'rgba(5, 5, 5, 0.7)',
            duration: 1.0
          });
        } else {
          gsap.to(blurOverlay, {
            backdropFilter: 'blur(0px)',
            background: 'rgba(5, 5, 5, 0)',
            duration: 0.3
          });
        }
      });
    }

    function goToSection(index, direction) {
      if (isHandlingScroll || index < 0 || index >= sections.length) return;
      if (index === currentSectionIndex) return;

      isHandlingScroll = true;
      accumulatedDelta = 0;
      const prevIndex = currentSectionIndex;
      currentSectionIndex = index;

      if (direction === 'next') {
        sectionStates[prevIndex].phase = SectionPhase.EXITING;
      } else {
        sectionStates[prevIndex].phase = SectionPhase.HIDDEN;
      }
      sectionStates[index].phase = SectionPhase.ENTERING;

      wrappers.forEach((w, i) => {
        w.style.overflowY = i === index ? 'auto' : 'hidden';
      });

      gsap.fromTo(sections[index],
        { y: direction === 'next' ? '100%' : '-100%', visibility: 'visible' },
        {
          y: '0%',
          duration: 1.2,
          ease: 'power2.inOut',
          onComplete: () => {
            sectionStates[index].phase = SectionPhase.ACTIVE;
            sectionStates[index].isAtTop = true;
            sectionStates[index].isAtBottom = false;
            isHandlingScroll = false;
          }
        }
      );

      if (direction === 'next') {
        gsap.to(sections[prevIndex], {
          visibility: 'hidden',
          duration: 0.1,
          delay: 1.1
        });
      } else {
        gsap.set(sections[prevIndex], { visibility: 'visible' });
      }

      updateBlurStates();
    }

    function handleWheel(e) {
      const currentState = sectionStates[currentSectionIndex];
      const isAtBoundary = currentState.isAtTop || currentState.isAtBottom;
      const isScrollingOutward = (e.deltaY > 0 && currentState.isAtBottom) ||
                                  (e.deltaY < 0 && currentState.isAtTop);

      if (isAtBoundary && isScrollingOutward) {
        accumulatedDelta += Math.abs(e.deltaY);

        if (accumulatedDelta < DAMPING_THRESHOLD) {
          e.preventDefault();
          return;
        }

        e.preventDefault();

        if (e.deltaY > 0 && currentSectionIndex < sections.length - 1) {
          goToSection(currentSectionIndex + 1, 'next');
        } else if (e.deltaY < 0 && currentSectionIndex > 0) {
          goToSection(currentSectionIndex - 1, 'prev');
        } else {
          accumulatedDelta = 0;
        }
      } else if (!isScrollingOutward) {
        accumulatedDelta = 0;
      }
    }

    let touchStartY = 0;
    let touchStartTime = 0;

    function handleTouchStart(e) {
      touchStartY = e.touches[0].clientY;
      touchStartTime = Date.now();
    }

    function handleTouchMove(e) {
      if (isHandlingScroll) {
        e.preventDefault();
        return;
      }

      const touchY = e.touches[0].clientY;
      const deltaY = touchStartY - touchY;
      const currentState = sectionStates[currentSectionIndex];

      if (deltaY > 50) {
        if (currentState.phase === SectionPhase.ACTIVE && !currentState.isAtBottom) {
          return;
        }
        if (currentSectionIndex < sections.length - 1) {
          e.preventDefault();
          goToSection(currentSectionIndex + 1, 'next');
          touchStartY = touchY;
        }
      } else if (deltaY < -50) {
        if (currentState.phase === SectionPhase.ACTIVE && !currentState.isAtTop) {
          return;
        }
        if (currentSectionIndex > 0) {
          e.preventDefault();
          goToSection(currentSectionIndex - 1, 'prev');
          touchStartY = touchY;
        }
      }
    }

    window.addEventListener('wheel', handleWheel, { passive: false });
    window.addEventListener('touchstart', handleTouchStart, { passive: true });
    window.addEventListener('touchmove', handleTouchMove, { passive: false });

    window.addEventListener('keydown', (e) => {
      const currentState = sectionStates[currentSectionIndex];

      if (e.key === 'ArrowDown' || e.key === 'PageDown') {
        e.preventDefault();
        if (currentState.isAtBottom && currentSectionIndex < sections.length - 1) {
          goToSection(currentSectionIndex + 1, 'next');
        }
      }
      if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        e.preventDefault();
        if (currentState.isAtTop && currentSectionIndex > 0) {
          goToSection(currentSectionIndex - 1, 'prev');
        }
      }
    });

    document.body.style.height = `${sections.length * window.innerHeight}px`;
    updateBlurStates();

    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        document.body.style.height = `${sections.length * window.innerHeight}px`;
        const newIsMobile = window.innerWidth <= 768;
        wrappers.forEach(wrapper => {
          const content = wrapper.querySelector('.section-scroll-content');
          if (content) {
            content.style.padding = newIsMobile ? '80px 5% 60px' : '100px 10% 50px 140px';
          }
        });
      }, 300);
    });
  }

  initProjectStacking();
</script>

<style>
  .project-page {
    padding: 0;
    min-height: 100vh;
    width: 100%;
    max-width: none;
    box-sizing: border-box;
  }

  .project-page section {
    position: relative;
    min-height: 100vh;
    height: 100vh;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    background-color: var(--bg-color, #050505);
    box-shadow: 0 -15px 30px rgba(0, 0, 0, 0.8);
    border-top: 1px solid #111;
    overflow: hidden;
  }

  .project-page .section-scroll-content {
    padding: 100px 10% 50px 140px;
    max-width: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100vh;
  }

  #overview { z-index: 1; box-shadow: none; border-top: none; }
  #features { z-index: 2; }
  #design-system { z-index: 3; }
  #tech { z-index: 4; }
  #future { z-index: 5; }

  .project-header {
    margin-bottom: 30px;
  }

  .project-category {
    color: var(--text-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 10px;
  }

  .project-title {
    font-size: 2.2rem;
    font-weight: 300;
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .project-title .cn {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .project-image-full {
    margin-bottom: 30px;
    border-radius: 12px;
    overflow: hidden;
  }

  .project-image-full img {
    width: 100%;
    height: auto;
    max-height: 300px;
    object-fit: cover;
    display: block;
  }

  .project-intro p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tech-tags span {
    padding: 6px 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .section-title {
    font-size: 1.8rem;
    font-weight: 300;
    margin-bottom: 30px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 25px;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-3px);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 10px;
    color: var(--text-main);
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .arch-content {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 30px;
  }

  .arch-item h3 {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 8px;
    color: var(--text-main);
  }

  .arch-item p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .rag-section {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 25px;
  }

  .rag-section h3 {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 15px;
  }

  .rag-steps {
    list-style: none;
    counter-reset: rag-counter;
  }

  .rag-steps li {
    position: relative;
    padding-left: 30px;
    margin-bottom: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.9rem;
  }

  .rag-steps li::before {
    counter-increment: rag-counter;
    content: counter(rag-counter);
    position: absolute;
    left: 0;
    top: 0;
    width: 20px;
    height: 20px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .perf-challenges {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 40px;
  }

  .perf-list {
    list-style: none;
  }

  .perf-list li {
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .perf-list li:last-child {
    border-bottom: none;
  }

  .challenge-item {
    margin-bottom: 20px;
  }

  .challenge-item h4 {
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 8px;
    color: var(--text-main);
  }

  .challenge-item p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .future-section {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .future-plans ul {
    list-style: none;
  }

  .future-plans li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 15px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .future-plans li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  .github-link {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 30px;
    background: var(--text-main);
    color: var(--bg-color);
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(255,255,255,0.1);
  }

  .btn-primary i {
    font-size: 1.3rem;
  }

  @media (max-width: 768px) {
    .project-page section {
      padding: 0;
      height: 100vh;
      overflow: hidden;
    }

    .project-page .section-scroll-content {
      padding: 80px 5% 60px;
      justify-content: flex-start;
    }

    .project-header {
      margin-bottom: 20px;
      margin-top: 0;
    }

    .project-category {
      font-size: 0.75rem;
      margin-bottom: 8px;
    }

    .project-title {
      font-size: 1.5rem;
      line-height: 1.3;
    }

    .project-title .cn {
      font-size: 1rem;
      margin-top: 6px;
    }

    .project-image-full {
      margin-bottom: 20px;
    }

    .project-image-full img {
      max-height: 200px;
    }

    .features-grid,
    .arch-content {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .perf-challenges,
    .future-section {
      grid-template-columns: 1fr;
      gap: 25px;
    }

    .feature-card,
    .rag-section {
      padding: 18px;
    }

    .section-title {
      font-size: 1.4rem;
      margin-bottom: 20px;
    }
  }
</style>
