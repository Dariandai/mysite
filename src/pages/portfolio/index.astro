---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    slug: 'project-alpha',
    titleEn: 'File Tools',
    titleCn: '本地文件智能检索与问答',
    category: 'Python / RAG',
    image: 'https://img.dar1an.dpdns.org/Picgo/2026/03-09-02-46-33.png'
  },
  {
    slug: 'system-ui',
    titleEn: 'System UI',
    titleCn: '后台数据可视化界面',
    category: 'Dashboard',
    image: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2670&auto=format&fit=crop'
  }
];
---

<BaseLayout title="Portfolio | Dar1an" description="精选项目作品集">
  <div class="page-content">
    <header class="page-header">
      <h1 class="page-title">
        <span class="en">Portfolio</span>
        <span class="cn">作品集</span>
      </h1>
    </header>

    <div class="projects-grid">
      {projects.map(project => (
        <a href={`/portfolio/${project.slug}/`} class="project-card">
          <div class="project-image">
            <img src={project.image} alt={project.titleEn} loading="lazy" decoding="async" />
          </div>
          <div class="project-info">
            <span class="project-category">{project.category}</span>
            <h2 class="project-title">
              <span class="en">{project.titleEn}</span>
              <span class="cn">{project.titleCn}</span>
            </h2>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 30px;
  }

  .project-card {
    background: var(--card-bg);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255,255,255,0.2);
  }

  .project-image {
    height: 220px;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-info {
    padding: 24px;
  }

  .project-category {
    color: var(--text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-family: var(--font-mono);
  }

  .project-title {
    margin-top: 8px;
  }

  .project-title .en {
    font-size: 1.2rem;
    font-weight: 500;
    display: block;
  }

  .project-title .cn {
    font-size: 0.9rem;
    margin-top: 4px;
    color: var(--text-muted);
    display: block;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .project-image {
      height: 180px;
    }
  }
</style>
