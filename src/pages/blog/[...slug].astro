---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = import.meta.glob('../../content/posts/*.md', { eager: true });

  return Object.values(allPosts).map((post: any) => {
    const slug = post.file.split('/').pop().replace('.md', '');
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { title, titleCn, date, description } = post.frontmatter;
const { Content } = post;
---

<BaseLayout title={`${title} | Dar1an`} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <div class="post-date">{date.replace(/-/g, '.')}</div>
      <h1 class="post-title">
        <span class="en">{title}</span>
        <span class="cn">{titleCn}</span>
      </h1>
      {description && <p class="post-description">{description}</p>}
    </header>

    <div class="post-content">
      <Content />
    </div>

  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 100px 10% 50px 140px;
    min-height: 100vh;
    width: 100%;
    box-sizing: border-box;
  }

  .post-header {
    margin-bottom: 40px;
    padding-bottom: 0;
  }

  .post-content {
    line-height: 1.9;
    color: #ccc;
    width: 100%;
    max-width: 100%;
  }

  .post-content :global(p),
  .post-content :global(h2),
  .post-content :global(ul) {
    max-width: 100%;
  }

  .post-date {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1.3;
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
  }

  .post-title .en {
    display: block;
    width: 100%;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .post-title .cn {
    font-size: 1.3rem;
    color: #888;
    margin-top: 4px;
    margin-bottom: 20px;
    display: block;
    width: 100%;
    word-wrap: break-word;
    overflow-wrap: break-word;
    line-height: 1.5;
    clear: both;
  }

  .post-description {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-top: 30px;
    margin-bottom: 50px;
    font-style: italic;
  }

  .post-content :global(p) {
    margin-bottom: 1.5em;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 2em 0 1em;
    color: var(--text-main);
  }

  .post-content :global(ul) {
    margin: 1em 0 1.5em 2em;
    list-style: disc;
  }

  .post-content :global(li) {
    margin-bottom: 0.5em;
  }

  .post-footer {
    margin-top: 60px;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  @media (max-width: 768px) {
    .blog-post {
      padding: 100px 5% 60px;
      padding-left: 5%;
    }

    .post-header {
      margin-bottom: 0;
      padding-top: 20px;
      padding-bottom: 25px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      height: auto;
    }

    .post-date {
      font-size: 0.85rem;
      margin-bottom: 25px;
      color: var(--text-muted);
    }

    .post-title {
      font-size: 1.5rem;
      line-height: 1.35;
      margin-bottom: 0;
    }

    .post-title .en {
      margin-bottom: 0;
      display: block;
    }

    .post-title .cn {
      font-size: 1rem;
      margin-top: 1px;
      margin-bottom: 0;
      line-height: 1.4;
      color: #888;
      display: block;
      clear: both;
    }

    .post-description {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-top: 20px;
      margin-bottom: 15px;
      color: var(--text-muted);
      font-style: italic;
    }

    .post-content {
      padding: 25px 15px 0;
      margin: 0;
    }

    .post-content :global(p:first-child) {
      margin-top: 0;
    }

    .post-content :global(p) {
      margin: 0 0 1.2em 0;
      line-height: 1.8;
    }

    .post-content :global(h2) {
      margin: 1.5em 0 0.8em;
      font-size: 1.3rem;
    }
  }
</style>
