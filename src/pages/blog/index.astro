---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = import.meta.glob('../../content/posts/*.md', { eager: true });
const sortedPosts = Object.values(allPosts)
  .map((post: any) => {
    const slug = post.file.split('/').pop().replace('.md', '');
    return {
      slug,
      date: post.frontmatter.date,
      titleEn: post.frontmatter.title,
      titleCn: post.frontmatter.titleCn,
      excerpt: post.frontmatter.description,
    };
  })
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Blog | Dar1an" description="思考与博客文章">
  <div class="page-content">
    <header class="page-header">
      <h1 class="page-title">
        <span class="en">Blog</span>
        <span class="cn">博客文章</span>
      </h1>
    </header>

    <div class="posts-list">
      {sortedPosts.map(post => (
        <article class="post-item">
          <time class="post-date">{post.date.replace(/-/g, '.')}</time>
          <a href={`/blog/${post.slug}/`} class="post-link">
            <h2 class="post-title">
              <span class="en">{post.titleEn}</span>
              <span class="cn">{post.titleCn}</span>
            </h2>
          </a>
          <p class="post-excerpt">{post.excerpt}</p>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  /* 列表样式 - 保持简洁列表 */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    padding: 32px 0;
    border-bottom: 1px solid var(--card-border);
    transition: all 0.25s ease;
  }

  .post-item:hover {
    padding-left: 16px;
    border-color: rgba(255,255,255,0.15);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-date {
    color: var(--text-muted);
    font-size: 0.75rem;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    display: block;
  }

  .post-link {
    display: block;
    margin-bottom: 12px;
  }

  .post-link:hover .en,
  .post-link:hover .cn {
    color: var(--text-main);
  }

  /* 使用 body 字体避免 g 被截断 - 增加行高和 padding 确保显示完整 */
  .post-title {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.6;
    padding-bottom: 4px;
    margin-bottom: 8px;
  }

  .post-title .en {
    font-weight: 600;
    letter-spacing: 0.3px;
    display: block;
    line-height: 1.5;
    padding-bottom: 2px;
  }

  .post-title .cn {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 6px;
    display: block;
    font-weight: 400;
    line-height: 1.5;
  }

  .post-excerpt {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .post-item {
      padding: 24px 0;
    }

    .post-title {
      font-size: 1.25rem;
      line-height: 1.5;
    }
  }
</style>
