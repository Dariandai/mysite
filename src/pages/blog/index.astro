---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await Astro.glob('../../content/posts/*.md');
const sortedPosts = posts
  .map(post => {
    const slug = post.file.split('/').pop().replace('.md', '');
    return {
      slug,
      date: post.frontmatter.date,
      titleEn: post.frontmatter.title,
      titleCn: post.frontmatter.titleCn,
      excerpt: post.frontmatter.description,
    };
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Blog | Dar1an" description="思考与博客文章">
  <div class="page-content">
    <header class="page-header">
      <h1 class="page-title">
        <span class="en">Blog</span>
        <span class="cn">博客文章</span>
      </h1>
      <p class="page-desc">关于设计、代码和数字生活的思考。</p>
    </header>

    <div class="posts-list">
      {sortedPosts.map(post => (
        <article class="post-item">
          <time class="post-date">{post.date.replace(/-/g, '.')}</time>
          <a href={`/blog/${post.slug}/`} class="post-link">
            <h2 class="post-title">
              <span class="en">{post.titleEn}</span>
              <span class="cn">{post.titleCn}</span>
            </h2>
          </a>
          <p class="post-excerpt">{post.excerpt}</p>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .page-content {
    padding: 140px 10% 50px;
    padding-left: 140px;
    min-height: 100vh;
    width: 100%;
    box-sizing: border-box;
  }

  .page-header {
    margin-bottom: 60px;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 15px;
  }

  .page-title .cn {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-top: 10px;
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .post-item {
    padding: 30px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .post-date {
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: 1px;
  }

  .post-link {
    display: block;
    margin: 15px 0;
  }

  .post-link:hover .en,
  .post-link:hover .cn {
    color: var(--text-main);
  }

  .post-title {
    font-size: 1.5rem;
    font-weight: 400;
  }

  .post-title .cn {
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 5px;
  }

  .post-excerpt {
    color: var(--text-muted);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .page-content {
      padding: 140px 5% 100px;
    }

    .page-title {
      font-size: 2rem;
    }
  }
</style>
