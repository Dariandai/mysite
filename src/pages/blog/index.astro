---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = import.meta.glob('../../content/posts/*.md', { eager: true });
const sortedPosts = Object.values(allPosts)
  .map((post: any) => {
    const slug = post.file.split('/').pop().replace('.md', '');
    return {
      slug,
      date: post.frontmatter.date,
      titleEn: post.frontmatter.title,
      titleCn: post.frontmatter.titleCn,
      excerpt: post.frontmatter.description,
      category: post.frontmatter.category || '思考',
    };
  })
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());

// 统计分类
const categories = ['全部', '思考', '技术'];
const categoryCounts: Record<string, number> = {
  '全部': sortedPosts.length,
  '思考': sortedPosts.filter((p: any) => p.category === '思考').length,
  '技术': sortedPosts.filter((p: any) => p.category === '技术').length,
};
---

<BaseLayout title="Blog | Dar1an" description="思考与博客文章">
  <div class="sub-page blog-page">
    <header class="page-header" data-animate="fade-up">
      <h1 class="page-title">
        <span class="en">Blog</span>
        <span class="cn">博客文章</span>
      </h1>
    </header>

    <!-- 分类标签栏 -->
    <div class="category-tabs" data-animate="fade-up" style="--delay: 0.05s" role="tablist" aria-label="Post categories">
      {categories.map(cat => (
        <button
          class="category-tab"
          data-category={cat}
          class:list={[{ active: cat === '全部' }]}
          aria-pressed={cat === '全部' ? 'true' : 'false'}
          role="tab"
        >
          <span class="cat-name">{cat}</span>
          <span class="cat-count">({categoryCounts[cat]})</span>
        </button>
      ))}
    </div>

    <div class="article-list">
      {sortedPosts.map((post, index) => (
        <a 
          href={`/blog/${post.slug}/`} 
          class="article-item" 
          data-animate="fade-up" 
          data-category={post.category}
          style={`--delay: ${0.1 + index * 0.06}s`}
        >
          <div class="article-index">
            <span class="index-num">{String(index + 1).padStart(2, '0')}</span>
          </div>
          <div class="article-body">
            <span class="article-date">{post.date}</span>
            <div class="article-content">
              <span class="article-title">{post.titleEn}</span>
              <span class="article-title-cn">{post.titleCn}</span>
            </div>
            {post.excerpt && <span class="article-excerpt">{post.excerpt}</span>}
          </div>
          <div class="article-arrow">
            <i class="ri-arrow-right-line"></i>
          </div>
        </a>
      ))}
    </div>

    <!-- 底部占位 -->
    <div class="blog-footer" data-animate="fade-up" style="--delay: 0.4s">
      <div class="footer-content">
        <span class="footer-icon"><i class="ri-quill-pen-line"></i></span>
        <span class="footer-text">更多思考正在路上...</span>
        <span class="footer-quote">"保持好奇心，持续输出"</span>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // 分类筛选功能
  const tabs = document.querySelectorAll('.category-tab');
  const items = document.querySelectorAll('.article-item');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const category = tab.getAttribute('data-category');
      
      // 更新标签状态
      tabs.forEach(t => {
        t.classList.remove('active');
        if (t instanceof HTMLElement) t.setAttribute('aria-pressed', 'false');
      });
      tab.classList.add('active');
      if (tab instanceof HTMLElement) tab.setAttribute('aria-pressed', 'true');
      
      // 过滤文章
      items.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        if (item instanceof HTMLElement) {
          if (category === '全部' || itemCategory === category) {
            item.style.display = 'grid';
          } else {
            item.style.display = 'none';
          }
        }
      });
    });
  });
</script>

<style>
  /* Wider blog reading layout (avoid overly narrow column) */
  .sub-page.blog-page {
    max-width: 1400px;
    padding-left: clamp(20px, 4vw, 56px);
    padding-right: clamp(20px, 4vw, 56px);
  }

  .blog-page {
    width: 100%;
    min-width: 0;
  }

  /* 分类标签栏 */
  .blog-page .category-tabs {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  .blog-page .category-tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-xs) var(--space-sm);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--pill-radius);
    color: var(--text-muted);
    font-size: var(--control-font);
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
    font-family: inherit;
  }

  .blog-page .category-tab:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .blog-page .category-tab.active {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-main);
  }

  .blog-page .cat-count {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  /* 文章列表 */
  .blog-page .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    min-width: 0;
    align-items: stretch;
  }

  .blog-page .article-item {
    display: grid;
    grid-template-columns: 48px 1fr 32px;
    align-items: center;
    gap: var(--space-md);
    padding: calc(var(--space-xl) - var(--space-xs)) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    text-decoration: none;
    color: inherit;
    transition: all 0.35s var(--ease-out-expo);
    opacity: 0;
    transform: translateY(16px);
    width: 100%;
    min-width: 0;
    max-width: none;
    align-self: stretch;
    justify-items: stretch;
  }

  .blog-page .article-item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .blog-page .article-item.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-page .article-item:hover {
    padding-left: var(--space-sm);
  }

  .blog-page .article-index {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-page .index-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .blog-page .article-item:hover .index-num {
    opacity: 0.9;
  }

  .blog-page .article-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .blog-page .article-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .blog-page .article-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    width: 100%;
    min-width: 0;
  }

  .blog-page .article-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text-main);
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
    line-height: 1.55;
    white-space: normal;
    word-break: normal;
    overflow-wrap: break-word;
  }

  .blog-page .article-title-cn {
    display: block;
    font-size: var(--control-font);
    color: var(--text-muted);
    transition: color 0.3s ease;
    line-height: 1.75;
    white-space: normal;
    word-break: break-word;
  }

  .blog-page .article-excerpt {
    font-size: var(--type-body-tight);
    color: var(--text-muted);
    opacity: 0.7;
    line-height: 1.5;
    margin-top: var(--space-2xs);
  }

  .blog-page .article-item:hover .article-title {
    color: rgba(255, 255, 255, 0.9);
  }

  .blog-page .article-item:hover .article-title-cn {
    color: rgba(255, 255, 255, 0.6);
  }

  .blog-page .article-item:hover .article-excerpt {
    opacity: 0.9;
  }

  .blog-page .article-arrow {
    opacity: 0;
    transform: translateX(calc(-1 * var(--space-xs)));
    transition: all 0.35s var(--ease-out-expo);
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .blog-page .article-item:hover .article-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .blog-page .article-arrow i {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  /* 底部占位 */
  .blog-page .blog-footer {
    margin-top: calc(var(--space-xl) + var(--space-xl));
    padding: var(--space-xl);
    background: rgba(255, 255, 255, 0.02) !important;
    background-clip: border-box !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    border-radius: var(--radius-sm) !important;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    box-sizing: border-box !important;
    overflow: visible !important;
  }

  .blog-page .blog-footer.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-page .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .blog-page .footer-icon {
    font-size: 1.8rem;
    color: var(--text-muted);
    opacity: 0.5;
  }

  .blog-page .footer-text {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .blog-page .footer-quote {
    font-size: var(--control-font);
    color: var(--text-muted);
    opacity: 0.6;
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .sub-page.blog-page {
      padding-left: clamp(16px, 4vw, 24px);
      padding-right: clamp(16px, 4vw, 24px);
    }

    .blog-page .article-list {
      width: min(100%, 860px);
      margin-left: auto;
      margin-right: auto;
    }

    .blog-page .category-tabs {
      margin-bottom: var(--space-md);
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .blog-page .category-tabs::-webkit-scrollbar {
      display: none;
    }

    .blog-page .category-tab {
      padding: 6px 12px;
      font-size: 0.8rem;
      flex: 0 0 auto;
    }

    .blog-page .article-item {
      display: grid !important;
      grid-template-columns: minmax(40px, 40px) minmax(0, 1fr) minmax(24px, 24px);
      gap: var(--space-sm);
      padding: var(--space-lg) 0;
      padding-left: var(--space-2xs);
      padding-right: var(--space-2xs);
      width: min(100%, 820px) !important;
      margin-left: auto;
      margin-right: auto;
      min-width: 0 !important;
      max-width: 820px !important;
      justify-items: stretch;
    }

    .blog-page .article-body,
    .blog-page .article-content {
      width: 100% !important;
      min-width: 0 !important;
      max-width: none !important;
    }

    .blog-page .article-title {
      font-size: 0.98rem;
    }

    .blog-page .article-title-cn {
      font-size: 0.8rem;
    }

    .blog-page .article-excerpt {
      display: none;
    }

    .blog-page .article-arrow {
      display: none;
    }

    .blog-page .blog-footer {
      margin-top: calc(var(--space-xl) + var(--space-lg));
      padding: calc(var(--space-lg) + var(--space-2xs)) var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .blog-page .article-item {
      display: grid !important;
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-sm);
      padding-left: var(--space-2xs);
      padding-right: var(--space-2xs);
      width: min(100%, 680px) !important;
      margin-left: auto;
      margin-right: auto;
      min-width: 0 !important;
      max-width: 680px !important;
    }

    .blog-page .article-index {
      display: none;
    }

    .blog-page .article-body,
    .blog-page .article-content {
      align-items: center;
      text-align: center;
    }

    .blog-page .article-date {
      font-size: 0.7rem;
    }
  }
</style>
