---
import BaseLayout from '../../layouts/BaseLayout.astro';

const skills = [
  { category: 'Development', items: ['Python / PyTorch / Scikit-learn', 'Flask / FastAPI / RESTful API', 'HTML / CSS / JavaScript', 'Java / Swagger'] },
  { category: 'Testing', items: ['Selenium / Pytest / Requests', 'JMeter Performance Testing', 'Postman / API Automation', 'Test Case / CI / Defect Management'] },
  { category: 'Database', items: ['MySQL Index Optimization', 'MongoDB Document Design', 'SQL Complex Queries'] },
  { category: 'Tools', items: ['Git / Docker / Linux', 'JIRA / 禅道', 'VS Code / Cursor'] }
];

const timelineEvents = [
  {
    date: '2022.09',
    titleEn: 'University Entry',
    titleCn: '大学入学',
    subtitle: '宁夏理工学院 · 土木工程',
    desc: '进入大学，开始土木工程专业的学习旅程',
    side: 'left',
    type: 'education'
  },
  {
    date: '2023.09',
    titleEn: 'Major Transfer',
    titleCn: '转专业',
    subtitle: '宁夏理工学院 · 计算机科学与技术',
    desc: '转入计算机科学专业，开始系统学习编程与软件开发',
    side: 'right',
    type: 'education'
  },
  {
    date: '2024.07',
    titleEn: 'Testing Intern',
    titleCn: '测试实习生',
    subtitle: '偌禾网络科技有限公司',
    desc: '参与支付系统测试，设计120+测试用例，搭建自动化框架',
    side: 'left',
    type: 'work'
  },
  {
    date: '2025.01',
    titleEn: 'L1 Ops Intern',
    titleCn: '运维实习生',
    subtitle: '神州融信科技 · 壳牌',
    desc: '远程支持200+加油站核心业务系统，处理工单200+',
    side: 'right',
    type: 'work'
  }
];
---

<BaseLayout title="About | Dar1an" description="关于 Dar1an">
  <div class="page-content about-page" data-stacking-cards>
    <!-- About Me with Fishbone Timeline -->
    <section class="about-hero" id="about-hero">
      <div class="about-container">
        <h1 class="page-title">
          <span class="en">About Me</span>
          <span class="cn">关于我</span>
        </h1>

        <!-- Fishbone Timeline -->
        <div class="fishbone-timeline">
          <div class="fishbone-spine"></div>
          {timelineEvents.map((event, index) => (
            <div class={`fishbone-item ${event.side} ${event.type}`}>
              <div class="fishbone-connector"></div>
              <div class="fishbone-node"></div>
              <div class="fishbone-content">
                <div class="fishbone-date">{event.date}</div>
                <div class="fishbone-header">
                  <span class="en">{event.titleEn}</span>
                  <span class="cn">{event.titleCn}</span>
                </div>
                <div class="fishbone-subtitle">{event.subtitle}</div>
                <p class="fishbone-desc">{event.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="fishbone-legend">
          <div class="fishbone-legend-item">
            <div class="fishbone-legend-dot education"></div>
            <span>教育 / Education</span>
          </div>
          <div class="fishbone-legend-item">
            <div class="fishbone-legend-dot work"></div>
            <span>实习 / Work</span>
          </div>
        </div>

        <!-- About Text & Actions -->
        <div class="about-bottom">
          <div class="about-text">
            <p>
              2023年我从土木工程转专业到计算机时，本以为是从"工地"到"写字楼"的转变。
              而AI的爆发让我意识到，没有永恒的风口，只有对系统可靠性的持续追求。
            </p>
            <p>
              无论是设计桥梁还是调试代码，本质都是在约束条件下解决真实问题。也让我明白：技术只是手段，理解真实世界才是价值所在。
              未来会怎样？我不知道，但我选择做那个使用工具的人，而非被工具定义的人。
            </p>
          </div>
          <div class="about-actions">
            <button class="btn-primary" onclick="openSocialModal()">
              <span class="en">Get in Touch</span>
              <span class="cn">联系我</span>
            </button>
            <a href="/portfolio/" class="btn-secondary">
              <span class="en">View Works</span>
              <span class="cn">查看作品</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 技能板块 -->
    <section class="skills-section" id="skills-section">
      <h2 class="section-heading">
        <span class="en">Skills & Tools</span>
        <span class="cn">技能与工具</span>
      </h2>
      <div class="skills-grid">
        {skills.map(skill => (
          <div class="card">
            <div class="card-header">
              <span>{skill.category}</span>
            </div>
            <ul class="card-list">
              {skill.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

  </div>

  <!-- Social Contact Modal -->
  <div class="social-modal-overlay" id="socialModalOverlay" onclick="closeSocialModal()"></div>
  <div class="social-modal" id="socialModal">
    <button class="social-modal-close" onclick="closeSocialModal()" aria-label="Close">
      <i class="ri-close-line"></i>
    </button>
    <h3 class="social-modal-title">
      <span class="en">Connect With Me</span>
      <span class="cn">与我联系</span>
    </h3>

    <div class="social-links two-col">
      <a href="https://github.com/Dry-U" target="_blank" class="social-link">
        <i class="ri-github-fill"></i>
        <span>GitHub</span>
      </a>
      <a href="https://x.com/Dar1an12?s=09" target="_blank" class="social-link">
        <i class="ri-twitter-x-line"></i>
        <span>X / Twitter</span>
      </a>
    </div>

    <div class="email-section">
      <h4>
        <span class="en">Email</span>
        <span class="cn">邮箱</span>
      </h4>
      <div class="email-list">
        <button class="email-item" onclick="copyEmail('hwe2377@gmail.com')">
          <i class="ri-mail-line"></i>
          <span>hwe2377@gmail.com</span>
          <i class="ri-file-copy-line copy-icon"></i>
        </button>
        <button class="email-item" onclick="copyEmail('Dar1an@126.com')">
          <i class="ri-mail-line"></i>
          <span>Dar1an@126.com</span>
          <i class="ri-file-copy-line copy-icon"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Copy Toast -->
  <div class="copy-toast" id="copyToast">邮箱已复制 / Email Copied</div>

  <script>
    // Social Modal Functions
    function openSocialModal() {
      const modal = document.getElementById('socialModal');
      const overlay = document.getElementById('socialModalOverlay');
      modal?.classList.add('active');
      overlay?.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeSocialModal() {
      const modal = document.getElementById('socialModal');
      const overlay = document.getElementById('socialModalOverlay');
      modal?.classList.remove('active');
      overlay?.classList.remove('active');
      document.body.style.overflow = '';
    }

    // Copy Email Function
    function copyEmail(email) {
      navigator.clipboard.writeText(email).then(() => {
        const toast = document.getElementById('copyToast');
        if (toast) {
          toast.textContent = `${email} 已复制 / Copied`;
          toast.classList.add('active');
          setTimeout(() => {
            toast.classList.remove('active');
          }, 2000);
        }
      }).catch(err => {
        console.error('Copy failed:', err);
      });
    }

    // Close modal on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSocialModal();
    });

    // Make functions available globally
    (window as any).openSocialModal = openSocialModal;
    (window as any).closeSocialModal = closeSocialModal;
    (window as any).copyEmail = copyEmail;

    // Initialize GSAP Stacking Cards - 使用统一模块
    import { initStackingCards } from '/src/scripts/stacking-cards.js';

    initStackingCards({
      sections: '.about-page section',
      sectionOrder: ['about-hero', 'skills-section']
    });

    // Initialize Timeline Animation - 使用单个 ScrollTrigger + GSAP stagger 优化性能
    function initTimelineAnimation() {
      const fishboneItems = document.querySelectorAll('.fishbone-item');
      const spine = document.querySelector('.fishbone-spine');

      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        // 设置初始状态
        gsap.set(fishboneItems, {
          opacity: 0,
          y: 30
        });

        // 使用单个 ScrollTrigger 批量触发动画，避免多个独立触发器的性能开销
        ScrollTrigger.create({
          trigger: '.fishbone-timeline',
          start: 'top 85%',
          once: true,
          onEnter: () => {
            // 脊柱动画 - 先显示
            if (spine) {
              gsap.fromTo(spine,
                { scaleY: 0, transformOrigin: 'top center' },
                { scaleY: 1, duration: 0.8, ease: 'power2.out' }
              );
            }

            // 使用 GSAP 内置 stagger，无需手动设置 delay，性能更好
            gsap.to(fishboneItems, {
              opacity: 1,
              y: 0,
              duration: 0.5,
              stagger: 0.08,  // 快速依次出现，最后一个延迟仅 0.24s
              ease: 'power2.out',
              delay: 0.2  // 等脊柱动画开始后再显示
            });
          }
        });
      } else {
        // 降级方案：CSS 动画 - 使用更短的延迟
        fishboneItems.forEach((item, index) => {
          (item as HTMLElement).style.animationDelay = `${index * 0.1}s`;
          item.classList.add('animate-in');
        });
        if (spine) spine.classList.add('animate-in');
      }
    }

    initTimelineAnimation();
  </script>
</BaseLayout>

<style>
  /* About 页面内容区 - 统一与其他子页面 */
  .about-page {
    padding: 120px 10% 50px 140px;
    min-height: 100vh;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  @media (max-width: 1024px) {
    .about-page {
      padding: 100px 5% 80px 100px;
    }
  }

  @media (max-width: 768px) {
    .about-page {
      padding: 90px 5% 80px;
    }

    .page-title {
      font-size: 1.8rem;
    }
  }

  /* GSAP Sections */
  .about-page section {
    position: relative;
    min-height: 100vh;
    height: 100vh;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    background-color: var(--bg-color, #050505);
    box-shadow: 0 -15px 30px rgba(0, 0, 0, 0.8);
    border-top: 1px solid #111;
    overflow: hidden;
  }

  .about-page .section-scroll-content {
    max-width: none;
    margin: 0;
  }

  #about-hero {
    z-index: 1;
    box-shadow: none;
    border-top: none;
  }

  #skills-section {
    z-index: 2;
  }

  /* About Hero Section */
  .about-hero {
    width: 100%;
    max-width: none;
  }

  .about-container {
    width: 100%;
    max-width: none;
    margin: 0;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 300;
    margin-bottom: 30px;
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .page-title .cn {
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 8px;
  }

  /* Fishbone Timeline */
  .fishbone-timeline {
    position: relative;
    padding: 20px 0 40px;
    margin-bottom: 30px;
  }

  .fishbone-spine {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom,
      transparent 0%,
      rgba(255,255,255,0.2) 5%,
      rgba(255,255,255,0.2) 95%,
      transparent 100%);
    transform: translateX(-50%);
  }

  .fishbone-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    margin-bottom: 40px;
    min-height: 100px;
    opacity: 0;
    transform: translateY(30px);
  }

  /* GSAP 动画状态 */
  .fishbone-item.gsap-animated {
    opacity: 1;
    transform: none;
  }

  /* CSS 降级动画 */
  .fishbone-item.animate-in {
    animation: fishboneFadeIn 0.6s ease forwards;
  }

  @keyframes fishboneFadeIn {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fishbone-item:last-child {
    margin-bottom: 0;
  }

  .fishbone-item.left {
    flex-direction: row;
    padding-right: calc(50% + 30px);
    justify-content: flex-end;
  }

  .fishbone-item.right {
    flex-direction: row-reverse;
    padding-left: calc(50% + 30px);
    justify-content: flex-end;
  }

  .fishbone-node {
    position: absolute;
    left: 50%;
    top: 15px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color, #050505);
    border: 3px solid rgba(255,255,255,0.3);
    transform: translateX(-50%);
    z-index: 2;
    transition: all 0.3s ease;
  }

  .fishbone-item.education .fishbone-node {
    border-color: rgba(100, 200, 255, 0.6);
  }

  .fishbone-item.work .fishbone-node {
    border-color: rgba(255, 200, 100, 0.6);
  }

  .fishbone-item:hover .fishbone-node {
    transform: translateX(-50%) scale(1.3);
    border-color: var(--text-main);
  }

  .fishbone-connector {
    position: absolute;
    left: 50%;
    top: 22px;
    width: 30px;
    height: 2px;
    background: rgba(255,255,255,0.15);
    transform-origin: left center;
  }

  .fishbone-item.left .fishbone-connector {
    transform: translateX(-100%) rotate(0deg);
  }

  .fishbone-item.right .fishbone-connector {
    transform: rotate(0deg);
  }

  .fishbone-content {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 20px;
    max-width: 320px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .fishbone-item:hover .fishbone-content {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
  }

  .fishbone-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 6px;
    font-weight: 500;
  }

  .fishbone-header {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .fishbone-header .en {
    display: block;
  }

  .fishbone-header .cn {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  .fishbone-subtitle {
    font-size: 0.85rem;
    color: var(--text-main);
    margin-bottom: 8px;
    opacity: 0.8;
  }

  .fishbone-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Legend */
  .fishbone-legend {
    display: flex;
    justify-content: center;
    gap: 30px;
    margin-bottom: 40px;
    font-size: 0.8rem;
  }

  .fishbone-legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
  }

  .fishbone-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid;
  }

  .fishbone-legend-dot.education {
    border-color: rgba(100, 200, 255, 0.6);
  }

  .fishbone-legend-dot.work {
    border-color: rgba(255, 200, 100, 0.6);
  }

  /* About Bottom Section */
  .about-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 40px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: start;
  }

  .about-text p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 16px;
    font-size: 1rem;
  }

  .about-text p:last-child {
    margin-bottom: 0;
  }

  .about-actions {
    display: flex;
    flex-direction: column;
    gap: 15px;
    min-width: 160px;
  }

  .btn-primary, .btn-secondary {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 24px;
    border-radius: 50px;
    transition: all 0.3s ease;
    cursor: pointer;
    text-align: center;
  }

  .btn-primary {
    background: var(--text-main);
    color: var(--bg-color);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(255,255,255,0.1);
  }

  .btn-secondary {
    border: 1px solid rgba(255,255,255,0.3);
  }

  .btn-secondary:hover {
    border-color: var(--text-main);
    background: rgba(255,255,255,0.05);
  }

  .btn-primary .en, .btn-secondary .en {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .btn-primary .cn, .btn-secondary .cn {
    font-size: 0.7rem;
    margin-top: 2px;
  }

  .btn-primary .cn { color: #555; }
  .btn-secondary .cn { color: var(--text-muted); }

  /* Skills Section */
  .skills-section {
    width: 100%;
    max-width: none;
  }

  .section-heading {
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 50px;
  }

  .section-heading .cn {
    display: block;
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 30px;
  }

  .skill-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    padding: 30px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .skill-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
  }

  .skill-category {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .skill-item {
    color: var(--text-main);
    font-size: 1rem;
    padding-left: 20px;
    position: relative;
  }

  .skill-item::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  /* Social Modal Styles */
  .social-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    z-index: 4000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .social-modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .social-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    width: 90%;
    max-width: 420px;
    background: rgba(15, 15, 15, 0.98);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px 30px;
    z-index: 4001;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .social-modal.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .social-modal-close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 5px;
    transition: 0.3s;
  }

  .social-modal-close:hover {
    color: var(--text-main);
  }

  .social-modal-title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 300;
    margin-bottom: 30px;
  }

  .social-modal-title .en {
    display: block;
    font-weight: 600;
  }

  .social-modal-title .cn {
    display: block;
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 5px;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 30px;
  }

  .social-links.two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .social-links.two-col .social-link {
    flex-direction: row;
    justify-content: center;
    padding: 18px 20px;
  }

  .social-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 15px 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    color: var(--text-muted);
    transition: all 0.3s ease;
    min-width: 80px;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-main);
    transform: translateY(-3px);
  }

  .social-link i {
    font-size: 1.8rem;
  }

  .social-link span {
    font-size: 0.75rem;
  }

  .email-section {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 25px;
  }

  .email-section h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
