---
import BaseLayout from '../../layouts/BaseLayout.astro';

const skills = [
  { category: 'Development', icon: 'ri-code-s-slash-line', items: ['Python / PyTorch / Scikit-learn', 'Flask / FastAPI / RESTful API', 'HTML / CSS / JavaScript', 'Java / Swagger'] },
  { category: 'Testing', icon: 'ri-test-tube-line', items: ['Selenium / Pytest / Requests', 'JMeter Performance Testing', 'Postman / API Automation', 'Test Case / CI / Defect Management'] },
  { category: 'Database', icon: 'ri-database-2-line', items: ['MySQL Index Optimization', 'MongoDB Document Design', 'SQL Complex Queries'] },
  { category: 'Tools', icon: 'ri-tools-line', items: ['Git / Docker / Linux', 'JIRA / 禅道', 'VS Code / Cursor'] }
];

const timelineEvents = [
  {
    date: '2022.09',
    titleEn: 'University Entry',
    titleCn: '大学入学',
    subtitle: '宁夏理工学院 · 土木工程',
    desc: '进入大学，开始土木工程专业的学习旅程',
    side: 'left',
    type: 'education'
  },
  {
    date: '2023.09',
    titleEn: 'Major Transfer',
    titleCn: '转专业',
    subtitle: '宁夏理工学院 · 计算机科学与技术',
    desc: '转入计算机科学专业，开始系统学习编程与软件开发',
    side: 'right',
    type: 'education'
  },
  {
    date: '2024.07',
    titleEn: 'Testing Intern',
    titleCn: '测试实习生',
    subtitle: '偌禾网络科技有限公司',
    desc: '参与支付系统测试，设计120+测试用例，搭建自动化框架',
    side: 'left',
    type: 'work'
  },
  {
    date: '2025.01',
    titleEn: 'L1 Ops Intern',
    titleCn: '运维实习生',
    subtitle: '神州融信科技 · 壳牌',
    desc: '远程支持200+加油站核心业务系统，处理工单200+',
    side: 'right',
    type: 'work'
  }
];
---

<BaseLayout title="About | Dar1an" description="关于 Dar1an">
  <section id="about-intro" class="stacked-page-section" aria-label="About intro">
    <div class="stacked-page-shell">
      <header class="page-header" data-animate="fade-up">
        <h1 class="page-title">
          <span class="en">About</span>
          <span class="cn">关于我</span>
        </h1>
      </header>
      <h2 class="section-title">
        <span class="sub">Profile / 简介</span>
        <div class="text-group">
          <span class="en">Who I Am</span>
          <span class="cn section-title-cn">我的背景与方向</span>
        </div>
      </h2>
      <div class="content-grid">
        <article class="unified-card about-intro-card">
        <div class="card-icon-header">
          <i class="ri-user-3-line"></i>
          <span>INTRODUCTION</span>
        </div>
        <p class="about-intro-text">
          2023 年从土木工程转到计算机后，我把重心放在“系统可靠性 + 工程落地”。
          无论是写代码、做测试还是运维支持，本质都在解决真实问题。
        </p>
        <p class="about-intro-text">
          我持续关注 AI 与开发效率工具，但更重视长期可维护性、清晰结构与稳定体验。
        </p>
        <div class="about-actions">
          <button class="btn-connect" onclick="openSocialModal()">
            <span class="en">Contact</span>
            <span class="cn">联系我</span>
          </button>
          <a href="/portfolio/" class="btn-connect">
            <span class="en">Portfolio</span>
            <span class="cn">查看作品</span>
          </a>
          <a
            href="https://img.dar1an.dpdns.org/main.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-connect resume-btn"
            aria-label="View or download resume PDF"
          >
            <i class="ri-file-download-line resume-icon" aria-hidden="true"></i>
            <span class="en">Resume PDF</span>
            <span class="cn">查看 / 下载简历</span>
          </a>
        </div>
        </article>
        <article class="unified-card about-stat-card">
        <div class="card-icon-header">
          <i class="ri-timer-line"></i>
          <span>FOCUS</span>
        </div>
        <ul class="card-items">
          <li>开发、测试、运维一体化实践</li>
          <li>工程可维护性与可观测性</li>
          <li>AI 工具的实际业务落地</li>
        </ul>
        </article>
      </div>
    </div>
  </section>

  <section id="about-timeline" class="stacked-page-section" aria-label="Career timeline">
    <div class="stacked-page-shell">
      <h2 class="section-title">
        <span class="sub">Timeline / 历程</span>
        <div class="text-group">
          <span class="en">My Journey</span>
          <span class="cn section-title-cn">学习与实践轨迹</span>
        </div>
      </h2>
      <div class="fishbone-timeline">
        <div class="fishbone-spine"></div>
        {timelineEvents.map((event) => (
          <div class={`fishbone-item ${event.side} ${event.type}`}>
            <div class="fishbone-connector"></div>
            <div class="fishbone-node"></div>
            <div class="fishbone-content">
              <div class="fishbone-date">{event.date}</div>
              <div class="fishbone-header">
                <span class="en">{event.titleEn}</span>
                <span class="cn">{event.titleCn}</span>
              </div>
              <div class="fishbone-subtitle">{event.subtitle}</div>
              <p class="fishbone-desc">{event.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="fishbone-legend">
        <div class="fishbone-legend-item">
          <div class="fishbone-legend-dot education"></div>
          <span>教育 / Education</span>
        </div>
        <div class="fishbone-legend-item">
          <div class="fishbone-legend-dot work"></div>
          <span>实习 / Work</span>
        </div>
      </div>
    </div>
  </section>

  <section id="about-skills" class="stacked-page-section" aria-label="Skills and tools">
    <div class="stacked-page-shell">
      <h2 class="section-title">
        <span class="sub">Skills / 技能</span>
        <div class="text-group">
          <span class="en">What I Use</span>
          <span class="cn section-title-cn">核心技能栈</span>
        </div>
      </h2>
      <div class="content-grid skills-grid-home">
        {skills.map((skill) => (
          <article class="unified-card skill-card">
          <div class="card-icon-header">
            <i class={skill.icon}></i>
            <span>{skill.category}</span>
          </div>
          <ul class="card-items">
            {skill.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
          </article>
        ))}
      </div>
      <footer>
        <div class="text-group">
          <span class="en">&copy; 2026 Dar1an. All Rights Reserved.</span>
          <span class="cn">保留所有权利。</span>
        </div>
      </footer>
    </div>
  </section>

  <!-- Social Contact Modal -->
  <div class="social-modal-overlay" id="socialModalOverlay" onclick="closeSocialModal()"></div>
  <div class="social-modal" id="socialModal">
    <button class="social-modal-close" onclick="closeSocialModal()" aria-label="Close">
      <i class="ri-close-line"></i>
    </button>
    <h3 class="social-modal-title">
      <span class="en">Connect With Me</span>
      <span class="cn">与我联系</span>
    </h3>

    <div class="social-links two-col">
      <a href="https://github.com/Dariandai" target="_blank" rel="noopener noreferrer" class="social-link">
        <i class="ri-github-fill"></i>
        <span>GitHub</span>
      </a>
      <a href="https://x.com/Dar1an12?s=09" target="_blank" rel="noopener noreferrer" class="social-link">
        <i class="ri-twitter-x-line"></i>
        <span>X / Twitter</span>
      </a>
    </div>

    <div class="email-section">
      <h4>
        <span class="en">Email</span>
        <span class="cn">邮箱</span>
      </h4>
      <div class="email-list">
        <button class="email-item" onclick="copyEmail('hwe2377@gmail.com')">
          <i class="ri-mail-line"></i>
          <span>hwe2377@gmail.com</span>
          <i class="ri-file-copy-line copy-icon"></i>
        </button>
        <button class="email-item" onclick="copyEmail('Dar1an@126.com')">
          <i class="ri-mail-line"></i>
          <span>Dar1an@126.com</span>
          <i class="ri-file-copy-line copy-icon"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Copy Toast -->
  <div class="copy-toast" id="copyToast">邮箱已复制 / Email Copied</div>
</BaseLayout>

<script>
  import { initStackingCards } from '../../scripts/stacking-cards.js';

  let hasTimelineAnimated = false;

  function playTimelineAnimation() {
    if (hasTimelineAnimated) return;

    const fishboneItems = document.querySelectorAll('.fishbone-item');
    const spine = document.querySelector('.fishbone-spine');
    if (!fishboneItems.length) return;

    if (typeof gsap !== 'undefined') {
      hasTimelineAnimated = true;

      gsap.set(fishboneItems, { opacity: 0, y: 20 });
      if (spine) gsap.set(spine, { scaleY: 0, transformOrigin: 'top center' });

      if (spine) {
        gsap.to(spine, {
          scaleY: 1,
          duration: 0.8,
          ease: 'power2.out'
        });
      }

      gsap.to(fishboneItems, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.08,
        ease: 'power2.out',
        delay: 0.12
      });
      return;
    }

    // GSAP may load slightly later than this page script.
    setTimeout(playTimelineAnimation, 80);
  }

  function handleSectionChange() {
    const section = arguments[1];
    if (section instanceof HTMLElement && section.id === 'about-timeline') {
      playTimelineAnimation();
    }
  }

  initStackingCards({
    sections: 'section',
    sectionOrder: ['about-intro', 'about-timeline', 'about-skills'],
    onSectionChange: handleSectionChange
  });

  // Social Modal Functions
  function openSocialModal() {
    const modal = document.getElementById('socialModal');
    const overlay = document.getElementById('socialModalOverlay');
    modal?.classList.add('active');
    overlay?.classList.add('active');
    const previousOverflow = document.body.style.overflow;
    document.body.dataset.prevOverflow = previousOverflow;
    document.body.style.overflow = 'hidden';
  }

  function closeSocialModal() {
    const modal = document.getElementById('socialModal');
    const overlay = document.getElementById('socialModalOverlay');
    modal?.classList.remove('active');
    overlay?.classList.remove('active');
    document.body.style.overflow = document.body.dataset.prevOverflow ?? '';
    delete document.body.dataset.prevOverflow;
  }

  function copyEmail() {
    const email = String(arguments[0] || '');
    navigator.clipboard.writeText(email).then(() => {
      const toast = document.getElementById('copyToast');
      if (toast) {
        toast.textContent = `${email} 已复制 / Copied`;
        toast.classList.add('active');
        setTimeout(() => toast.classList.remove('active'), 2000);
      }
    }).catch(() => {
      // Keep production console clean; the UX fallback is toast not shown.
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSocialModal();
  });

  window.openSocialModal = openSocialModal;
  window.closeSocialModal = closeSocialModal;
  window.copyEmail = copyEmail;

  // If user opens directly on the timeline section, keep animation behavior consistent.
  if (window.stackingCardsInstance?.getCurrentIndex?.() === 1) {
    playTimelineAnimation();
  }
</script>

<style>
  .about-intro-card {
    gap: 14px;
  }

  .about-intro-text {
    color: var(--text-muted);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .about-actions {
    margin-top: 8px;
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .about-actions .btn-connect {
    margin-top: 0;
    appearance: none;
    -webkit-appearance: none;
    text-decoration: none;
    color: var(--text-main);
    font-family: inherit;
    line-height: 1.2;
    padding: 12px 28px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  .about-actions .btn-connect:hover {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(255, 255, 255, 0.92);
  }

  .about-actions .btn-connect:hover .en {
    color: #111;
  }

  .about-actions .btn-connect:hover .cn {
    color: #444;
  }

  .about-stat-card {
    max-width: none;
  }

  .resume-icon {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    transition: transform 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo);
  }

  .about-actions .btn-connect:hover .resume-icon {
    transform: translateY(-1px);
    color: #111;
  }

  /* ── Social Modal ── */
  .social-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(12px);
    z-index: 4000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .social-modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .social-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    width: 90%;
    max-width: 400px;
    background: rgba(10, 10, 10, 0.98);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: calc(var(--space-lg) + var(--space-2xs)) calc(var(--space-md) + var(--space-2xs));
    z-index: 4001;
    opacity: 0;
    visibility: hidden;
    transition: all 0.35s var(--ease-out-expo);
  }

  .social-modal.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .social-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: rgba(255,255,255,0.05);
    border: none;
    color: var(--text-muted);
    font-size: 1.2rem;
    cursor: pointer;
    padding: var(--space-xs);
    border-radius: var(--radius-sm);
    transition: all 0.3s ease;
  }

  .social-modal-close:hover {
    background: rgba(255,255,255,0.1);
    color: var(--text-main);
  }

  .social-modal-title {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .social-modal-title .en {
    display: block;
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--text-main);
    margin-bottom: 4px;
  }

  .social-modal-title .cn {
    display: block;
    font-size: var(--control-font);
    color: var(--text-muted);
  }

  .social-links.two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .social-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-sm);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    color: var(--text-main);
    transform: translateY(-2px);
  }

  .social-link i {
    font-size: 1.8rem;
  }

  .social-link span {
    font-size: 0.75rem;
  }

  .email-section {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: var(--space-md);
  }

  .email-section h4 {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-sm);
  }

  .email-section h4 .cn {
    font-weight: 400;
    color: var(--text-muted);
  }

  .email-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .email-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-sm);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    color: var(--text-main);
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    font-family: inherit;
    font-size: var(--type-body-tight);
  }

  .email-item:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .email-item i:first-child {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .email-item span {
    flex: 1;
    text-align: left;
  }

  .copy-icon {
    color: var(--text-muted);
    font-size: 0.95rem;
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .email-item:hover .copy-icon {
    opacity: 1;
    color: var(--text-main);
  }

  .copy-toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255, 255, 255, 0.95);
    color: #000;
    padding: var(--space-sm) var(--space-md);
    border-radius: 30px;
    font-weight: 600;
    font-size: var(--control-font);
    z-index: 5000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .copy-toast.active {
    opacity: 1;
    visibility: visible;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .about-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .about-actions .btn-connect {
      justify-content: center;
    }

    .about-stat-card {
      max-width: none;
    }
  }

  /* ── Fishbone Timeline ── */

  .fishbone-timeline {
    position: relative;
    width: 100%;
    padding: var(--space-md) 0 calc(var(--space-xl) + var(--space-2xs));
    margin-bottom: calc(var(--space-lg) + var(--space-2xs));
    box-sizing: border-box;
  }

  .fishbone-spine {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom,
      transparent 0%,
      rgba(255,255,255,0.2) 5%,
      rgba(255,255,255,0.2) 95%,
      transparent 100%);
    transform: translateX(-50%);
  }

  .fishbone-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    margin-bottom: calc(var(--space-xl) + var(--space-2xs));
    min-height: 100px;
    opacity: 1;
    transform: none;
  }

  .fishbone-item:last-child {
    margin-bottom: 0;
  }

  .fishbone-item.left {
    flex-direction: row;
    padding-right: calc(50% + var(--space-lg));
    justify-content: flex-end;
  }

  .fishbone-item.right {
    flex-direction: row-reverse;
    padding-left: calc(50% + var(--space-lg));
    justify-content: flex-end;
  }

  .fishbone-node {
    position: absolute;
    left: 50%;
    top: var(--space-sm);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color, #050505);
    border: 3px solid rgba(255,255,255,0.3);
    transform: translateX(-50%);
    z-index: 2;
    transition: all 0.3s ease;
  }

  .fishbone-item.education .fishbone-node {
    border-color: rgba(100, 200, 255, 0.6);
  }

  .fishbone-item.work .fishbone-node {
    border-color: rgba(255, 200, 100, 0.6);
  }

  .fishbone-item:hover .fishbone-node {
    transform: translateX(-50%) scale(1.3);
    border-color: var(--text-main);
  }

  .fishbone-connector {
    position: absolute;
    left: 50%;
    top: calc(var(--space-md) - var(--space-2xs));
    width: var(--space-lg);
    height: 2px;
    background: rgba(255,255,255,0.15);
    transform-origin: left center;
  }

  .fishbone-item.left .fishbone-connector {
    transform: translateX(-100%) rotate(0deg);
  }

  .fishbone-item.right .fishbone-connector {
    transform: rotate(0deg);
  }

  .fishbone-content {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    max-width: 320px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .fishbone-item:hover .fishbone-content {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.15);
    transform: translateY(calc(-1 * var(--space-2xs)));
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
  }

  .fishbone-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: var(--space-2xs);
    font-weight: 500;
  }

  .fishbone-header {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: var(--space-3xs);
  }

  .fishbone-header .en {
    display: block;
  }

  .fishbone-header .cn {
    display: block;
    font-size: var(--control-font);
    color: var(--text-muted);
    margin-top: var(--space-3xs);
  }

  .fishbone-subtitle {
    font-size: var(--control-font);
    color: var(--text-main);
    margin-bottom: var(--space-xs);
    opacity: 0.8;
  }

  .fishbone-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Fishbone Legend */
  .fishbone-legend {
    display: flex;
    justify-content: center;
    gap: calc(var(--space-lg) + var(--space-2xs));
    margin-bottom: calc(var(--space-xl) + var(--space-2xs));
    font-size: 0.8rem;
  }

