---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { name: 'Figma', desc: '界面协作设计', icon: 'ri-pencil-ruler-2-fill', url: 'https://figma.com' },
  { name: 'Dribbble', desc: '设计师灵感社区', icon: 'ri-dribbble-line', url: 'https://dribbble.com' },
  { name: 'GitHub', desc: '开源代码托管', icon: 'ri-github-fill', url: 'https://github.com' },
  { name: 'Vercel', desc: '前端部署托管', icon: 'ri-cloud-windy-fill', url: 'https://vercel.com' },
  { name: 'Notion', desc: '笔记知识管理', icon: 'ri-sticky-note-line', url: 'https://notion.so' },
  { name: 'Raycast', desc: 'Mac 启动器', icon: 'ri-command-line', url: 'https://raycast.com' }
];
---

<BaseLayout title="Share | Dar1an" description="好用的工具与资源推荐">
  <div class="page-content">
    <header class="page-header">
      <h1 class="page-title">
        <span class="en">Tools & Resources</span>
        <span class="cn">工具与资源</span>
      </h1>
    </header>

    <div class="tools-grid">
      {tools.map(tool => (
        <a href={tool.url} target="_blank" class="tool-card">
          <div class="tool-icon"><i class={tool.icon}></i></div>
          <div class="tool-info">
            <span class="tool-name">{tool.name}</span>
            <span class="tool-desc">{tool.desc}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-content {
    padding: 100px 10% 50px 140px;
    min-height: 100vh;
    width: 100%;
    box-sizing: border-box;
  }

  .page-header {
    margin-bottom: 60px;
  }

  .page-title {
    font-size: 3rem;
    font-weight: 300;
    margin-bottom: 15px;
  }

  .page-title .cn {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-top: 10px;
    display: block;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 30px;
    background: var(--card-bg);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .tool-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255,255,255,0.2);
  }

  .tool-icon {
    font-size: 2rem;
    color: #fff;
    width: 48px;
    text-align: center;
  }

  .tool-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tool-name {
    font-weight: 500;
    font-size: 1.1rem;
  }

  .tool-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .page-content {
      padding: 100px 5% 80px;
    }

    .page-title {
      font-size: 2rem;
    }

    .tools-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .tool-card {
      padding: 25px;
    }
  }
</style>
