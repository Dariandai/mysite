---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { name: 'Figma', desc: '界面协作设计', icon: 'ri-pencil-ruler-2-fill', url: 'https://figma.com' },
  { name: 'Dribbble', desc: '设计师灵感社区', icon: 'ri-dribbble-line', url: 'https://dribbble.com' },
  { name: 'GitHub', desc: '开源代码托管', icon: 'ri-github-fill', url: 'https://github.com' },
  { name: 'Vercel', desc: '前端部署托管', icon: 'ri-cloud-windy-fill', url: 'https://vercel.com' },
  { name: 'Notion', desc: '笔记知识管理', icon: 'ri-sticky-note-line', url: 'https://notion.so' },
  { name: 'Raycast', desc: 'Mac 启动器', icon: 'ri-command-line', url: 'https://raycast.com' }
];
---

<BaseLayout title="Share | Dar1an" description="好用的工具与资源推荐">
  <div class="page-content">
    <header class="page-header">
      <h1 class="page-title">
        <span class="en">Tools & Resources</span>
        <span class="cn">工具与资源</span>
      </h1>
    </header>

    <div class="tools-grid">
      {tools.map(tool => (
        <a href={tool.url} target="_blank" class="card tool-card">
          <div class="card-header">
            <i class={tool.icon}></i>
            <span>{tool.name}</span>
          </div>
          <ul class="card-list">
            <li>{tool.desc}</li>
          </ul>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
  }

  .tool-card .card-list {
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .tools-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
